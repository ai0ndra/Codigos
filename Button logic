#include <ServoEasing.hpp>

// --- DIAGNOSTICO ---
RTC_DATA_ATTR int restartCount = 0;

// --- PINES DE SERVOS ---
// Ajustados segun tu ultimo codigo que funcionaba (Codigo_con_boton)
#define PIN_S1 23
#define PIN_S2 33
#define PIN_S3 32
#define PIN_S4 25
#define PIN_S5 22

// --- PINES DE CONTROL ---
const int START_BUTTON_PIN = 19; // Boton de inicio (D19 a GND)
const int PAUSE_SWITCH_PIN = 21; // Interruptor de pausa (D21 a GND)

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

int velocidad = 25;
int espera    = 1000;

// Explicacion: 'firstPress' se pone en 'false' despues de la primera vez
// para que el brazo no tenga que hacer la calibracion lenta (Homing)
// cada vez que quieras repetir la secuencia.
bool firstPress = true;
int lastStartState = HIGH;

void detenerTodo() {
  SERVO1.stop();
  SERVO2.stop();
  SERVO3.stop();
  SERVO4.stop();
  SERVO5.stop();
}

void verificarBotonPausa() {
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    Serial.println(">> MODO PAUSA: DETENIDO POR D21 <<");
    detenerTodo();
    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      delay(50);
    }
    Serial.println(">> REANUDANDO...");
  }
}

void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino) {
  Serial.print("Acoplando servo en pin "); Serial.println(pin);
  servo.attach(pin);
  for (int p = 45; p <= destino; p++) {
    verificarBotonPausa();
    servo.write(p);
    delay(40);
  }
}

void moverUnServo(ServoEasing &s, int target, const char* name) {
  if (abs(s.getCurrentAngle() - target) <= 1) return;
  
  Serial.print("Moviendo "); Serial.print(name); Serial.print(" a "); Serial.println(target);
  s.startEaseTo(target, velocidad);
  delay(150);

  while (abs(s.getCurrentAngle() - target) > 1) {
    verificarBotonPausa();
    if (!s.isMoving()) {
      s.startEaseTo(target, velocidad);
      delay(150);
    }
    delay(20);
  }
}

void esperarPausaYDelay(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarBotonPausa();
    delay(10);
  }
}

void setup() {
  Serial.begin(115200);
  restartCount++;
  
  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);
  
  delay(1000);
  Serial.println("\n==============================");
  Serial.print("SISTEMA LISTO. Intento: "); Serial.println(restartCount);
  
  // Diagnostico de pines al arrancar
  Serial.print("Boton START (D19): ");
  Serial.println(digitalRead(START_BUTTON_PIN) == LOW ? "PRESIONADO (GND)" : "LIBRE (HIGH)");

  Serial.print("Interruptor PAUSA (D21): ");
  Serial.println(digitalRead(PAUSE_SWITCH_PIN) == LOW ? "CERRADO (PAUSA)" : "ABIERTO (OK)");
  Serial.println("==============================\n");

  lastStartState = digitalRead(START_BUTTON_PIN);
}

void ejecutarSecuencia() {
  Serial.println("--- Ejecutando secuencia ---");

  moverUnServo(SERVO1, 90, "S1");
  moverUnServo(SERVO2, 90, "S2");
  moverUnServo(SERVO3, 90, "S3");
  moverUnServo(SERVO4, 90, "S4");
  moverUnServo(SERVO5, 90, "S5");
  esperarPausaYDelay(espera);

  moverUnServo(SERVO1, 60, "S1");
  moverUnServo(SERVO4, 130, "S4");
  moverUnServo(SERVO3, 55, "S3");
  moverUnServo(SERVO2, 125, "S2");
  moverUnServo(SERVO5, 45, "S5");
  esperarPausaYDelay(espera);
  
  moverUnServo(SERVO2, 80, "S2");
  moverUnServo(SERVO4, 90, "S4");
  esperarPausaYDelay(espera);
  
  moverUnServo(SERVO1, 90, "S1");
  moverUnServo(SERVO2, 95, "S2");
  moverUnServo(SERVO3, 90, "S3");
  moverUnServo(SERVO4, 60, "S4");
  moverUnServo(SERVO5, 90, "S5");
  esperarPausaYDelay(espera);
  
  Serial.println("--- Secuencia terminada ---");
}

void loop() {
  // Comprobacion visual del boton en el monitor serial
  int currentStartState = digitalRead(START_BUTTON_PIN);

  // Si detectamos un cambio de HIGH a LOW (pulsacion)
  if (currentStartState == LOW && lastStartState == HIGH) {
    delay(50); // Debounce
    if (digitalRead(START_BUTTON_PIN) == LOW) {
      Serial.println("\n[CLICK] Boton START detectado.");

      if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
        Serial.println("AVISO: No puedo empezar porque el interruptor de PAUSA (D21) esta cerrado.");
      } else {
        
        if (firstPress) {
          Serial.println("Iniciando calibracion (solo la primera vez)...");
          alcanzarHomeConPasos(SERVO1, PIN_S1, 90);
          alcanzarHomeConPasos(SERVO2, PIN_S2, 90);
          alcanzarHomeConPasos(SERVO3, PIN_S3, 90);
          alcanzarHomeConPasos(SERVO4, PIN_S4, 90);
          alcanzarHomeConPasos(SERVO5, PIN_S5, 90);

          SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
          SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
          SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
          SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
          SERVO5.setEasingType(EASE_CUBIC_IN_OUT);

          firstPress = false; // Aqui se pone en false para no repetir esto
          esperarPausaYDelay(espera);
        }

        ejecutarSecuencia();
        Serial.println("Listo para repetir al presionar START.");
      }

      // Esperar a que sueltes el boton
      while(digitalRead(START_BUTTON_PIN) == LOW) {
        delay(10);
      }
      currentStartState = HIGH;
    }
  }

  lastStartState = currentStartState;
  delay(15);
}
