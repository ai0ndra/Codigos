#include <ServoEasing.hpp>

// Variable para detectar reinicios en el Monitor Serial (ESP32)
RTC_DATA_ATTR int restartCount = 0;

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

// VELOCIDAD para el movimiento normal (Grados por segundo)
int velocidad = 20; 
int espera    = 1000;

// Configuración de los botones (IMPORTANTE: Conectar ambos a un pin GND físico)
const int START_BUTTON_PIN = 19; // Botón momentáneo para Iniciar (D19 a GND)
const int PAUSE_SWITCH_PIN = 21; // Interruptor sostenido (Switch) para Pausar (D21 a GND)

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;

// Verifica el interruptor de pausa con filtrado de ruido (Debounce) mejorado
void verificarBotonPausa() {
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    // Confirmamos que la señal se mantiene LOW (Pausa activada) durante 150ms
    // Esto evita que el ruido eléctrico de los motores active la pausa por error.
    unsigned long t_deteccion = millis();
    while (millis() - t_deteccion < 150) {
      if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) return; // Falsa alarma (ruido)
      delay(5);
    }

    if (!isPaused) {
      Serial.println("!! PAUSA ACTIVADA (Interruptor D21 detectado) !!");
      SERVO1.stop();
      SERVO2.stop();
      SERVO3.stop();
      SERVO4.stop();
      SERVO5.stop();
      isPaused = true;
    }

    // Mientras el interruptor siga en LOW, nos quedamos aquí bloqueados
    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      delay(50);
    }

    if (isPaused) {
      Serial.println(">> REANUDANDO MOVIMIENTO...");
      isPaused = false;
    }
  }
}

// Función para alcanzar la posición inicial usando "pasos" manuales (Seguridad)
void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino) {
  Serial.print("Acoplando servo en pin "); Serial.println(pin);
  servo.attach(pin);

  // Iniciamos desde 45 para asegurar que el movimiento sea visible y lento
  for (int p = 45; p <= destino; p++) {
    verificarBotonPausa();
    servo.write(p);
    delay(50); // 50ms por grado = movimiento muy seguro
  }
  Serial.println("Home alcanzado.");
}

// Función para mover UN SOLO SERVO con detección de pausa y reintento automático
void moverUnServo(ServoEasing &s, int target, const char* name) {
  // Si ya estamos cerca del objetivo, no hacemos nada
  if (abs(s.getCurrentAngle() - target) <= 1) {
    Serial.print(name); Serial.println(" ya en posicion.");
    return;
  }

  Serial.print("Moviendo "); Serial.print(name); Serial.print(" -> "); Serial.println(target);
  
  // Iniciamos el movimiento
  s.startEaseTo(target, velocidad);
  delay(100); // Delay para que la librería inicialice el movimiento

  // Bucle principal del servo: continúa hasta llegar al destino
  while (abs(s.getCurrentAngle() - target) > 1) {
    
    verificarBotonPausa(); // Verifica si el interruptor D21 está cerrado
    
    // Si el servo se detuvo pero no ha llegado (posible interrupción por pausa o error)
    if (!s.isMoving() && !isPaused && abs(s.getCurrentAngle() - target) > 1) {
      Serial.print("...re-activando "); Serial.println(name);
      s.startEaseTo(target, velocidad);
      delay(100);
    }
    
    // Mientras el servo se esté moviendo, monitoreamos el interruptor de pausa
    while (s.isMoving()) {
      if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
        verificarBotonPausa();
        break; // Salimos del bucle isMoving para que el código superior maneje la reanudación
      }
      delay(20);
    }
    
    delay(20); // Pequeña espera de estabilidad
  }
  Serial.print("OK: "); Serial.println(name);
  delay(100); // Pausa entre servos para reducir picos de corriente
}

// Función para esperar un tiempo (delay) sin bloquear el interruptor de pausa
void esperarPausaYDelay(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarBotonPausa();
    delay(10);
  }
}

void setup() {
  Serial.begin(115200);
  restartCount++;
  
  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);
  
  delay(500);
  Serial.println("\n==========================================");
  Serial.print("  SISTEMA INICIADO - Intento nro: ");
  Serial.println(restartCount);
  Serial.println("==========================================");
  
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    Serial.println(">>> AVISO: Interruptor de PAUSA detectado como ACTIVADO.");
  }

  lastStartState = digitalRead(START_BUTTON_PIN);
  Serial.println("Brazo Robot listo. Presione START para comenzar.");
}

void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia de trabajo...");

  // -------- SECUENCIA 1: IR A HOME (90) --------
  moverUnServo(SERVO1, 90, "SERVO 1");
  moverUnServo(SERVO2, 90, "SERVO 2");
  moverUnServo(SERVO3, 90, "SERVO 3");
  moverUnServo(SERVO4, 90, "SERVO 4");
  moverUnServo(SERVO5, 90, "SERVO 5");
  esperarPausaYDelay(espera);

  // -------- SECUENCIA 2: IR A TRABAJO (Orden: 1, 4, 3, 2, 5) --------
  moverUnServo(SERVO1, 60, "SERVO 1");
  moverUnServo(SERVO4, 130, "SERVO 4");
  moverUnServo(SERVO3, 55, "SERVO 3");
  moverUnServo(SERVO2, 125, "SERVO 2");
  moverUnServo(SERVO5, 45, "SERVO 5");
  esperarPausaYDelay(espera);
  
  // PARTE 2: 2(80), luego 4(90)
  moverUnServo(SERVO2, 80, "SERVO 2");
  moverUnServo(SERVO4, 90, "SERVO 4");
  esperarPausaYDelay(espera);
  
  // PARTE 3: 1(90), 2(95), 3(90), 4(60), 5(90)
  moverUnServo(SERVO1, 90, "SERVO 1");
  moverUnServo(SERVO2, 95, "SERVO 2");
  moverUnServo(SERVO3, 90, "SERVO 3");
  moverUnServo(SERVO4, 60, "SERVO 4");
  moverUnServo(SERVO5, 90, "SERVO 5");
  esperarPausaYDelay(espera);
  
  Serial.println(">>> SECUENCIA FINALIZADA CON EXITO <<<");
}

void loop() {
  // Vigilancia constante del interruptor de pausa
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    verificarBotonPausa();
    return;
  }

  int currentStartState = digitalRead(START_BUTTON_PIN);

  // Detectar pulsación de INICIO (Transición de HIGH a LOW)
  if (currentStartState == LOW && lastStartState == HIGH) {
    // Debounce fuerte para evitar disparos por ruido eléctrico (100ms)
    delay(100);
    if (digitalRead(START_BUTTON_PIN) == LOW) {
      
      // PRIMER INICIO: Homing secuencial lento
      if (firstPress) {
        Serial.println("\n--- Iniciando Homing de Seguridad ---");
        alcanzarHomeConPasos(SERVO1, 23, 90);
        alcanzarHomeConPasos(SERVO2, 33, 90);
        alcanzarHomeConPasos(SERVO3, 32, 90);
        alcanzarHomeConPasos(SERVO4, 25, 90);
        alcanzarHomeConPasos(SERVO5, 22, 90);

        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);
        
        firstPress = false;
        esperarPausaYDelay(espera);
      }

      // Ejecutar la secuencia principal en el orden correcto
      ejecutarSecuencia();
      
      Serial.println("\n>>> Secuencia Completada con Exito <<<");
      Serial.println("Esperando nueva pulsacion de START...\n");

      // Delay de seguridad y limpieza de estado del botón
      delay(500);
      currentStartState = digitalRead(START_BUTTON_PIN);
    }
  }

  lastStartState = currentStartState;
  delay(20);
}
