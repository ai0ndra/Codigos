#include <ServoEasing.hpp>

// Variable para detectar reinicios en el Monitor Serial (ESP32)
RTC_DATA_ATTR int restartCount = 0;

// Estados del sistema
enum State { READY, MOVING, PAUSED };
State currentState = READY;

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

// VELOCIDAD para el movimiento normal (Grados por segundo)
int velocidad = 20; 
int espera    = 1000;

// Configuración de los botones (IMPORTANTE: Conectar ambos a un pin GND físico)
const int START_BUTTON_PIN = 19; // Botón momentáneo para Iniciar (D19 a GND)
const int PAUSE_SWITCH_PIN = 21; // Interruptor sostenido (Switch) para Pausar (D21 a GND)

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;

// Verifica el interruptor de pausa y el botón de inicio como reanudación
void verificarBotonPausa() {
  // 1. Detección del interruptor de PAUSA (Pin 21)
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    if (!isPaused) {
      Serial.println("!! PAUSA POR INTERRUPTOR (Pin 21) !!");
      detenerTodo();
      isPaused = true;
      currentState = PAUSED;
    }

    // Bloqueo mientras el interruptor de pausa esté cerrado
    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      delay(50);
    }
  }

  // 2. Lógica de Reanudación (Si estamos pausados, esperamos a que se abra el interruptor O se pulse START)
  if (isPaused) {
    // Si el interruptor ya está abierto (HIGH), podemos reanudar con el botón START
    if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) {
      Serial.println("Esperando pulsacion de START para reanudar...");

      while (isPaused) {
        if (digitalRead(START_BUTTON_PIN) == LOW) {
          delay(100); // Debounce
          if (digitalRead(START_BUTTON_PIN) == LOW) {
            Serial.println(">> REANUDANDO POR BOTON START...");
            isPaused = false;
            currentState = MOVING;
            // Esperar a que suelte el botón para no disparar otro evento
            while(digitalRead(START_BUTTON_PIN) == LOW) delay(10);
          }
        }
        // Si vuelve a cerrar el interruptor de pausa mientras espera, volvemos al estado de bloqueo
        if (digitalRead(PAUSE_SWITCH_PIN) == LOW) return;
        delay(20);
      }
    }
  }
}

void detenerTodo() {
  SERVO1.stop();
  SERVO2.stop();
  SERVO3.stop();
  SERVO4.stop();
  SERVO5.stop();
}

// Función para alcanzar la posición inicial usando "pasos" manuales (Seguridad)
void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino) {
  Serial.print("Acoplando servo en pin "); Serial.println(pin);
  servo.attach(pin);

  // Iniciamos desde 45 para asegurar que el movimiento sea visible y lento
  for (int p = 45; p <= destino; p++) {
    verificarBotonPausa();
    servo.write(p);
    delay(50); // 50ms por grado = movimiento muy seguro
  }
  Serial.println("Home alcanzado.");
}

// Función para mover UN SOLO SERVO con detección de pausa y reintento automático
void moverUnServo(ServoEasing &s, int target, const char* name) {
  if (abs(s.getCurrentAngle() - target) <= 1) return;

  Serial.print("Ejecutando: "); Serial.print(name); Serial.print(" -> "); Serial.println(target);
  
  unsigned long startTime = millis();
  s.startEaseTo(target, velocidad);
  delay(150);

  while (abs(s.getCurrentAngle() - target) > 1) {
    verificarBotonPausa();
    
    // Si el sistema se pausó y reanudó, debemos reiniciar el movimiento hacia el objetivo
    if (!s.isMoving() && !isPaused && abs(s.getCurrentAngle() - target) > 1) {
      Serial.print("Re-iniciando trayectoria de "); Serial.println(name);
      s.startEaseTo(target, velocidad);
      delay(150);
    }
    
    // Monitoreo mientras se mueve
    while (s.isMoving()) {
      // Si se detecta pausa durante el movimiento
      if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
        verificarBotonPausa();
        break;
      }
      delay(15);

      // Safety Timeout (Evita que el código se cuelgue si un servo se traba)
      if (millis() - startTime > 15000) { // 15 segundos max por movimiento
         Serial.print("TIMEOUT en "); Serial.println(name);
         break;
      }
    }
    delay(15);
  }
  Serial.print("Completado: "); Serial.println(name);
  delay(200); // Pausa de estabilizacion mecanica
}

// Función para esperar un tiempo (delay) sin bloquear el interruptor de pausa
void esperarPausaYDelay(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarBotonPausa();
    delay(10);
  }
}

void setup() {
  Serial.begin(115200);
  restartCount++;
  
  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);
  
  delay(1000); // Espera extendida para estabilizar voltaje
  Serial.println("\n==========================================");
  Serial.print("  BRAZO ROBOTICO - Arraque nro: ");
  Serial.println(restartCount);
  Serial.println("==========================================");
  
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    Serial.println(">>> ESTADO INICIAL: PAUSA (Interruptor D21 Cerrado)");
    isPaused = true;
    currentState = PAUSED;
  }

  lastStartState = digitalRead(START_BUTTON_PIN);
  Serial.println("Listo. Presione START (D19) para iniciar secuencia.");
}

void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia de trabajo...");

  // -------- SECUENCIA 1: IR A HOME (90) --------
  moverUnServo(SERVO1, 90, "SERVO 1");
  moverUnServo(SERVO2, 90, "SERVO 2");
  moverUnServo(SERVO3, 90, "SERVO 3");
  moverUnServo(SERVO4, 90, "SERVO 4");
  moverUnServo(SERVO5, 90, "SERVO 5");
  esperarPausaYDelay(espera);

  // -------- SECUENCIA 2: IR A TRABAJO (Orden: 1, 4, 3, 2, 5) --------
  moverUnServo(SERVO1, 60, "SERVO 1");
  moverUnServo(SERVO4, 130, "SERVO 4");
  moverUnServo(SERVO3, 55, "SERVO 3");
  moverUnServo(SERVO2, 125, "SERVO 2");
  moverUnServo(SERVO5, 45, "SERVO 5");
  esperarPausaYDelay(espera);
  
  // PARTE 2: 2(80), luego 4(90)
  moverUnServo(SERVO2, 80, "SERVO 2");
  moverUnServo(SERVO4, 90, "SERVO 4");
  esperarPausaYDelay(espera);
  
  // PARTE 3: 1(90), 2(95), 3(90), 4(60), 5(90)
  moverUnServo(SERVO1, 90, "SERVO 1");
  moverUnServo(SERVO2, 95, "SERVO 2");
  moverUnServo(SERVO3, 90, "SERVO 3");
  moverUnServo(SERVO4, 60, "SERVO 4");
  moverUnServo(SERVO5, 90, "SERVO 5");
  esperarPausaYDelay(espera);
  
  Serial.println(">>> SECUENCIA FINALIZADA CON EXITO <<<");
}

void loop() {
  // 1. Monitoreo constante de la pausa
  verificarBotonPausa();

  // 2. Lógica del botón START (Inicio de secuencia)
  int currentStartState = digitalRead(START_BUTTON_PIN);

  // Solo iniciamos si no estamos pausados y detectamos flanco de bajada (NO button)
  if (currentState == READY && currentStartState == LOW && lastStartState == HIGH) {
    delay(100);
    if (digitalRead(START_BUTTON_PIN) == LOW) {
      
      currentState = MOVING;

      if (firstPress) {
        Serial.println("\n[1/2] Realizando calibracion inicial...");
        alcanzarHomeConPasos(SERVO1, 23, 90);
        alcanzarHomeConPasos(SERVO2, 33, 90);
        alcanzarHomeConPasos(SERVO3, 32, 90);
        alcanzarHomeConPasos(SERVO4, 25, 90);
        alcanzarHomeConPasos(SERVO5, 22, 90);

        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);
        
        firstPress = false;
        esperarPausaYDelay(espera);
      }

      Serial.println("\n[2/2] Iniciando secuencia de trabajo principal");
      ejecutarSecuencia();
      
      Serial.println("\n>>> PROCESO FINALIZADO <<<");
      Serial.println("El brazo volvera a iniciar al pulsar START.\n");

      currentState = READY;
      delay(500);
      currentStartState = digitalRead(START_BUTTON_PIN);
    }
  }

  lastStartState = currentStartState;
  delay(15);
}
