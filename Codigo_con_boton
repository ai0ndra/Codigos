#include <ServoEasing.hpp>

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

// VELOCIDAD para el movimiento normal (Grados por segundo)
int velocidad = 30;
int espera    = 1000;

// Configuración del botón
const int BUTTON_PIN = 19; // Pin de entrada para el botón
const int GROUND_PIN = 21; // Pin que actuará como Tierra (GND) para el botón
bool firstPress = true;

// Función para alcanzar la posición inicial usando "pasos" manuales (Seguridad)
void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino) {
  servo.attach(pin);
  // Forzamos un inicio en 45 grados para garantizar un movimiento lento y visible hasta 90.
  for (int p = 45; p <= destino; p++) {
    servo.write(p);
    delay(40); // 40ms por grado = movimiento fluido
  }
}

void setup() {
  Serial.begin(115200);

  // Configurar el pin 21 como salida en LOW para que actúe como GND para el botón
  pinMode(GROUND_PIN, OUTPUT);
  digitalWrite(GROUND_PIN, LOW);

  // Configurar el pin 19 como entrada con Pull-up.
  // Como el botón es NORMALMENTE CERRADO (NC), el pin leerá LOW mientras no se pulse.
  // Al pulsar el botón, el circuito se ABRE y el pin leerá HIGH.
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  Serial.println("Brazo Robot Listo.");
  Serial.println("Esperando que se abra el boton (NC) para comenzar...");
}

void ejecutarSecuencia() {
  Serial.println("Ejecutando secuencia de trabajo...");

  // -------- SECUENCIA 1: IR A HOME (90) --------
  SERVO1.easeTo(90, velocidad);
  SERVO2.easeTo(90, velocidad);
  SERVO3.easeTo(90, velocidad);
  SERVO4.easeTo(90, velocidad);
  SERVO5.easeTo(90, velocidad);

  // Sincronizar movimientos
  synchronizeAllServosStartAndWaitForAllServosToStop();
  delay(espera);

  // -------- SECUENCIA 2: IR A TRABAJO --------
  SERVO1.easeTo(60, velocidad);
  SERVO4.easeTo(125, velocidad);
  SERVO3.easeTo(55, velocidad);
  SERVO2.easeTo(125, velocidad);
  SERVO5.easeTo(45, velocidad); 

  synchronizeAllServosStartAndWaitForAllServosToStop();
  delay(espera);
  
  SERVO2.easeTo(80, velocidad);
  SERVO4.easeTo(90, velocidad);

  synchronizeAllServosStartAndWaitForAllServosToStop();
  delay(espera);
  
  SERVO1.easeTo(90, velocidad);
  SERVO2.easeTo(95, velocidad);
  SERVO3.easeTo(90, velocidad);
  SERVO4.easeTo(60, velocidad);
  SERVO5.easeTo(90, velocidad);

  synchronizeAllServosStartAndWaitForAllServosToStop();
  delay(espera);

  Serial.println("Secuencia finalizada. Esperando nueva pulsacion...");
}

void loop() {
  // Como el botón es NC (Normalmente Cerrado), el pin 19 está conectado a GND (Pin 21) normalmente.
  // Al presionar el botón, el contacto se ABRE y el pin 19 sube a HIGH por el Pull-up.

  if (digitalRead(BUTTON_PIN) == HIGH) {
    delay(50); // Antirebote
    if (digitalRead(BUTTON_PIN) == HIGH) {

      // Primera pulsación: Homing lento de seguridad
      if (firstPress) {
        Serial.println("Activacion detectada: Realizando Homing inicial...");

        alcanzarHomeConPasos(SERVO1, 23, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO2, 33, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO3, 32, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO4, 25, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO5, 22, 90);
        delay(500);

        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);

        firstPress = false;
        delay(espera);
      }

      // Ejecutar la secuencia principal
      ejecutarSecuencia();

      // Esperar a que el botón se vuelva a cerrar (vuelva a LOW) antes de permitir otro ciclo
      while (digitalRead(BUTTON_PIN) == HIGH) {
        delay(10);
      }
    }
  }
}
