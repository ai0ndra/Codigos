#include <ServoEasing.hpp>

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

// VELOCIDAD para el movimiento normal (Grados por segundo)
int velocidad = 30;
int espera    = 1000;

// Configuración de los botones (IMPORTANTE: Conectar ambos a un pin GND físico)
const int START_BUTTON_PIN = 19; // Botón momentáneo para Iniciar (D19 a GND)
const int PAUSE_SWITCH_PIN = 21; // Interruptor sostenido (Switch) para Pausar (D21 a GND)

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;

// Esta variable se guarda en la memoria RTC y sobrevive a reinicios suaves (BROWN-OUT)
RTC_DATA_ATTR int resetCount = 0;

// Verifica el interruptor de pausa y detiene el movimiento FISICAMENTE de inmediato
void verificarBotonPausa() {
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    delay(100); // Filtro anti-ruido fuerte (Debounce)
    if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) return; // Pico de ruido ignorado

    if (!isPaused) {
      Serial.println("\n[!] PAUSA DETECTADA (D21 en LOW). Deteniendo servos...");
      SERVO1.stop();
      SERVO2.stop();
      SERVO3.stop();
      SERVO4.stop();
      SERVO5.stop();
      isPaused = true;
    }

    // Bloqueo total mientras el interruptor esté cerrado
    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      delay(50);
    }

    if (isPaused) {
      Serial.println("[!] REANUDANDO (D21 en HIGH).");
      isPaused = false;
    }
  }
}

// Función para alcanzar la posición inicial usando "pasos" manuales (Seguridad)
void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino, const char* name) {
  Serial.print("Homing "); Serial.println(name);
  servo.attach(pin);
  for (int p = 45; p <= destino; p++) {
    verificarBotonPausa();
    servo.write(p);
    delay(40);
  }
  delay(200); // Pequeña pausa entre servos para evitar picos de corriente
}

// Función para mover UN SOLO SERVO de forma secuencial y con detección de pausa REANUDABLE
void moverUnServo(ServoEasing &s, int target, const char* name) {
  Serial.print("Moviendo "); Serial.print(name); Serial.print(" -> "); Serial.println(target);

  while (abs(s.getCurrentAngle() - target) > 1) {

    // Si estamos pausados antes de empezar, esperamos
    verificarBotonPausa();

    // Iniciar o continuar movimiento hacia el objetivo
    s.startEaseTo(target, velocidad);
    delay(50); // Tiempo para que la libreria registre el movimiento

    // Mientras se esté moviendo hacia el objetivo
    while (s.isMoving()) {
      if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
        verificarBotonPausa();
        // Si pausamos, salimos de este bucle interno para re-evaluar la posición al reanudar
        break;
      }
      delay(10);
    }

    // Si terminó de moverse y no estamos en pausa, verificamos si llegó al destino real
    if (!isPaused && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
}

// Función para esperar un tiempo (delay) sin bloquear el interruptor de pausa
void esperarPausaYDelay(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarBotonPausa();
    delay(10);
  }
}

void setup() {
  Serial.begin(115200);

  // Pequeña espera al arrancar para que la energía se estabilice
  delay(1000);

  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);

  resetCount++; // Aumentar el contador de reinicios

  Serial.println("\n#############################################");
  Serial.print("--- SISTEMA INICIADO - Reset #"); Serial.print(resetCount); Serial.println(" ---");
  if (resetCount > 1) {
    Serial.println("ALERTA: El ESP32 se ha reiniciado solo.");
    Serial.println("Esto significa que los motores estan consumiendo demasiada energia.");
    Serial.println("Revisa tu bateria o fuente de alimentacion.");
  }
  Serial.println("#############################################\n");

  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    Serial.println("AVISO: El interruptor de PAUSA esta detectado como CERRADO.");
  }

  lastStartState = digitalRead(START_BUTTON_PIN);
  Serial.println("Brazo Robot Listo. Esperando Start en D19...");
}

void ejecutarSecuencia() {
  Serial.println("\n>>> INICIANDO SECUENCIA DE TRABAJO <<<");

  // -------- SECUENCIA 1: IR A HOME (90) --------
  moverUnServo(SERVO1, 90, "Joint 1");
  moverUnServo(SERVO2, 90, "Joint 2");
  moverUnServo(SERVO3, 90, "Joint 3");
  moverUnServo(SERVO4, 90, "Joint 4");
  moverUnServo(SERVO5, 90, "Joint 5");
  esperarPausaYDelay(espera);

  // -------- SECUENCIA 2: TRABAJO (Orden: 1, 4, 3, 2, 5) --------
  moverUnServo(SERVO1, 60, "Joint 1");
  moverUnServo(SERVO4, 125, "Joint 4");
  moverUnServo(SERVO3, 55, "Joint 3");
  moverUnServo(SERVO2, 125, "Joint 2");
  moverUnServo(SERVO5, 45, "Joint 5");
  esperarPausaYDelay(espera);

  // PARTE 2: 2(80), luego 4(90)
  moverUnServo(SERVO2, 80, "Joint 2");
  moverUnServo(SERVO4, 90, "Joint 4");
  esperarPausaYDelay(espera);

  // PARTE 3: 1(90), 2(95), 3(90), 4(60), 5(90)
  moverUnServo(SERVO1, 90, "Joint 1");
  moverUnServo(SERVO2, 95, "Joint 2");
  moverUnServo(SERVO3, 90, "Joint 3");
  moverUnServo(SERVO4, 60, "Joint 4");
  moverUnServo(SERVO5, 90, "Joint 5");
  esperarPausaYDelay(espera);

  Serial.println(">>> SECUENCIA COMPLETADA CON EXITO <<<");
}

void loop() {
  // Vigilancia constante del interruptor de pausa
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    verificarBotonPausa();
    return;
  }

  int currentStartState = digitalRead(START_BUTTON_PIN);

  // Detectar pulsación de INICIO (HIGH a LOW)
  if (currentStartState == LOW && lastStartState == HIGH) {
    delay(200); // Debounce fuerte para el botón de inicio (200ms)
    if (digitalRead(START_BUTTON_PIN) == LOW) {

      // PRIMER INICIO: Homing secuencial lento
      if (firstPress) {
        Serial.println("\n[!] Realizando Homing inicial de seguridad...");
        alcanzarHomeConPasos(SERVO1, 23, 90, "Servo 1");
        alcanzarHomeConPasos(SERVO2, 33, 90, "Servo 2");
        alcanzarHomeConPasos(SERVO3, 32, 90, "Servo 3");
        alcanzarHomeConPasos(SERVO4, 25, 90, "Servo 4");
        alcanzarHomeConPasos(SERVO5, 22, 90, "Servo 5");

        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);

        firstPress = false;
        esperarPausaYDelay(espera);
      }

      // Ejecutar la secuencia principal en el orden correcto
      ejecutarSecuencia();

      currentStartState = digitalRead(START_BUTTON_PIN);
      Serial.println("\n[LISTO] Esperando nueva pulsacion en D19 para repetir.");
    }
  }

  lastStartState = currentStartState;
  delay(20);
}
