#include <ServoEasing.hpp>

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

// VELOCIDAD para el movimiento normal (Grados por segundo)
int velocidad = 30;
int espera    = 1000;

// Configuración de los botones (IMPORTANTE: Conectar ambos a un pin GND físico)
const int START_BUTTON_PIN = 19; // Botón para Iniciar/Reanudar (D19 a GND)
const int PAUSE_BUTTON_PIN = 21; // Botón para Pausar (D21 a GND)

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;

// Función para alcanzar la posición inicial usando "pasos" manuales (Seguridad)
void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino) {
  servo.attach(pin);
  // Forzamos un inicio en 45 grados para garantizar un movimiento lento y visible hasta 90.
  for (int p = 45; p <= destino; p++) {
    servo.write(p);
    delay(40); // 40ms por grado = movimiento fluido
  }
}

// Verifica el botón de pausa y detiene/reanuda los servos
void verificarBotonPausa() {
  // Si se presiona el botón de PAUSA (D21 va a LOW)
  if (digitalRead(PAUSE_BUTTON_PIN) == LOW) {
    delay(50); // Debounce
    if (digitalRead(PAUSE_BUTTON_PIN) == LOW) {
      if (!isPaused) {
        Serial.println("PAUSA ACTIVADA.");
        ServoEasing::pauseAllServos();
        isPaused = true;
      } else {
        Serial.println("REANUDANDO...");
        ServoEasing::resumeAllServos();
        isPaused = false;
      }
      // Esperar a que suelte el botón
      while (digitalRead(PAUSE_BUTTON_PIN) == LOW) delay(10);
    }
  }

  // Mientras esté pausado, nos quedamos bloqueados aquí vigilando el botón
  while (isPaused) {
    if (digitalRead(PAUSE_BUTTON_PIN) == LOW) {
      delay(50);
      Serial.println("REANUDANDO...");
      ServoEasing::resumeAllServos();
      isPaused = false;
      while (digitalRead(PAUSE_BUTTON_PIN) == LOW) delay(10);
    }
    delay(10);
  }
}

// Función para esperar a que termine el movimiento sin bloquear el botón de pausa
void esperarMovimientoConPausa() {
  // Mientras cualquier servo esté en movimiento
  while (SERVO1.isMovingAndEasing() || SERVO2.isMovingAndEasing() ||
         SERVO3.isMovingAndEasing() || SERVO4.isMovingAndEasing() ||
         SERVO5.isMovingAndEasing()) {

    verificarBotonPausa();
    delay(10);
  }
}

// Función para esperar un tiempo (delay) sin bloquear el botón de pausa
void esperarPausaYDelay(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarBotonPausa();
    delay(10);
  }
}

void setup() {
  Serial.begin(115200);

  // Configurar los pines de los botones como entrada con Pull-up interno
  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_BUTTON_PIN, INPUT_PULLUP);

  delay(100);
  lastStartState = digitalRead(START_BUTTON_PIN);

  Serial.println("Brazo Robot Listo.");
  Serial.println("Conecta D19 a GND para INICIAR.");
  Serial.println("Conecta D21 a GND para PAUSAR/REANUDAR.");
}

void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia...");

  // -------- SECUENCIA 1: IR A HOME (90) --------
  SERVO1.setEaseTo(90, velocidad);
  SERVO2.setEaseTo(90, velocidad);
  SERVO3.setEaseTo(90, velocidad);
  SERVO4.setEaseTo(90, velocidad);
  SERVO5.setEaseTo(90, velocidad);

  ServoEasing::synchronizeAllServosStart();
  esperarMovimientoConPausa();
  esperarPausaYDelay(espera);

  // -------- SECUENCIA 2: IR A TRABAJO --------
  SERVO1.setEaseTo(60, velocidad);
  SERVO4.setEaseTo(125, velocidad);
  SERVO3.setEaseTo(55, velocidad);
  SERVO2.setEaseTo(125, velocidad);
  SERVO5.setEaseTo(45, velocidad);

  ServoEasing::synchronizeAllServosStart();
  esperarMovimientoConPausa();
  esperarPausaYDelay(espera);

  SERVO2.setEaseTo(80, velocidad);
  SERVO4.setEaseTo(90, velocidad);

  ServoEasing::synchronizeAllServosStart();
  esperarMovimientoConPausa();
  esperarPausaYDelay(espera);

  SERVO1.setEaseTo(90, velocidad);
  SERVO2.setEaseTo(95, velocidad);
  SERVO3.setEaseTo(90, velocidad);
  SERVO4.setEaseTo(60, velocidad);
  SERVO5.setEaseTo(90, velocidad);
  
  ServoEasing::synchronizeAllServosStart();
  esperarMovimientoConPausa();
  esperarPausaYDelay(espera);
  
  Serial.println("Secuencia finalizada.");
}

void loop() {
  int currentStartState = digitalRead(START_BUTTON_PIN);

  // Detectar pulsación de INICIO (HIGH a LOW)
  if (currentStartState == LOW && lastStartState == HIGH) {
    delay(50);
    if (digitalRead(START_BUTTON_PIN) == LOW) {

      if (firstPress) {
        Serial.println("Realizando Homing de seguridad...");
        alcanzarHomeConPasos(SERVO1, 23, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO2, 33, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO3, 32, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO4, 25, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO5, 22, 90);
        delay(500);

        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);

        firstPress = false;
        esperarPausaYDelay(espera);
      }

      ejecutarSecuencia();
      currentStartState = digitalRead(START_BUTTON_PIN);
    }
  }

  lastStartState = currentStartState;
  delay(20);
}
