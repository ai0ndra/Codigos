#include <ServoEasing.hpp>

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

// VELOCIDAD para el movimiento normal (Grados por segundo)
int velocidad = 30;
int espera    = 1000;

// Configuración de los botones (IMPORTANTE: Conectar ambos a un pin GND físico)
const int START_BUTTON_PIN = 19; // Botón momentáneo para Iniciar (D19 a GND)
const int PAUSE_SWITCH_PIN = 21; // Interruptor sostenido (Switch) para Pausar (D21 a GND)

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;

// Verifica el interruptor de pausa y detiene el movimiento FISICAMENTE de inmediato
void verificarBotonPausa() {
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    delay(100); // Filtro de ruido fuerte
    if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) return;

    if (!isPaused) {
      Serial.println(">>> PAUSA ACTIVADA por hardware (D21 LOW) <<<");
      SERVO1.stop();
      SERVO2.stop();
      SERVO3.stop();
      SERVO4.stop();
      SERVO5.stop();
      isPaused = true;
    }

    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      delay(50);
    }

    if (isPaused) {
      Serial.println(">>> REANUDANDO (D21 HIGH) <<<");
      isPaused = false;
    }
  }
}

// Función para alcanzar la posición inicial usando "pasos" manuales (Seguridad)
void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino) {
  servo.attach(pin);
  for (int p = 45; p <= destino; p++) {
    verificarBotonPausa();
    servo.write(p);
    delay(40);
  }
}

// Función para mover UN SOLO SERVO de forma secuencial y con detección de pausa REANUDABLE
void moverUnServo(ServoEasing &s, int target, const char* name) {
  Serial.print("Comenzando: "); Serial.print(name); Serial.print(" hacia "); Serial.println(target);

  bool llegado = false;
  while (!llegado) {

    // Si estamos en pausa, esperamos antes de dar la orden de movimiento
    verificarBotonPausa();

    // Dar la orden de movimiento una sola vez o al reanudar
    s.startEaseTo(target, velocidad);
    delay(50); // Estabilización

    // Mientras se mueva, vigilamos la pausa
    while (s.isMoving()) {
      if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
        verificarBotonPausa();
        // Al salir de verificarBotonPausa (cuando abren el switch),
        // salimos de este while(isMoving) para relanzar la orden s.startEaseTo
        break;
      }
      delay(10);
    }

    // Si terminó de moverse y no estamos pausados, verificamos si llegó
    if (!isPaused && !s.isMoving()) {
      Serial.print("Finalizado: "); Serial.println(name);
      llegado = true;
    }
  }
}

// Función para esperar un tiempo (delay) sin bloquear el interruptor de pausa
void esperarPausaYDelay(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarBotonPausa();
    delay(10);
  }
}

void setup() {
  Serial.begin(115200);

  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);

  delay(200);
  Serial.println("\n--- SISTEMA REINICIADO ---");

  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    Serial.println("AVISO: El interruptor de PAUSA esta detectado como CERRADO.");
  }

  lastStartState = digitalRead(START_BUTTON_PIN);
}

void ejecutarSecuencia() {
  Serial.println("--- INICIANDO SECUENCIA ---");

  // -------- SECUENCIA 1: IR A HOME (90) --------
  moverUnServo(SERVO1, 90, "Joint 1");
  moverUnServo(SERVO2, 90, "Joint 2");
  moverUnServo(SERVO3, 90, "Joint 3");
  moverUnServo(SERVO4, 90, "Joint 4");
  moverUnServo(SERVO5, 90, "Joint 5");
  esperarPausaYDelay(espera);

  // -------- SECUENCIA 2: TRABAJO (Orden: 1, 4, 3, 2, 5) --------
  moverUnServo(SERVO1, 60, "Joint 1");
  moverUnServo(SERVO4, 125, "Joint 4");
  moverUnServo(SERVO3, 55, "Joint 3");
  moverUnServo(SERVO2, 125, "Joint 2");
  moverUnServo(SERVO5, 45, "Joint 5");
  esperarPausaYDelay(espera);

  // PARTE 2: 2(80), luego 4(90)
  moverUnServo(SERVO2, 80, "Joint 2");
  moverUnServo(SERVO4, 90, "Joint 4");
  esperarPausaYDelay(espera);

  // PARTE 3: 1(90), 2(95), 3(90), 4(60), 5(90)
  moverUnServo(SERVO1, 90, "Joint 1");
  moverUnServo(SERVO2, 95, "Joint 2");
  moverUnServo(SERVO3, 90, "Joint 3");
  moverUnServo(SERVO4, 60, "Joint 4");
  moverUnServo(SERVO5, 90, "Joint 5");
  esperarPausaYDelay(espera);

  Serial.println("--- SECUENCIA COMPLETADA ---");
}

void loop() {
  // Si el interruptor de pausa está activado, bloqueamos el inicio
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    verificarBotonPausa();
    return;
  }

  int currentStartState = digitalRead(START_BUTTON_PIN);

  // Detectar pulsación de INICIO (HIGH a LOW)
  if (currentStartState == LOW && lastStartState == HIGH) {
    delay(50);
    if (digitalRead(START_BUTTON_PIN) == LOW) {

      if (firstPress) {
        Serial.println("Homing Inicial de Seguridad...");
        alcanzarHomeConPasos(SERVO1, 23, 90);
        alcanzarHomeConPasos(SERVO2, 33, 90);
        alcanzarHomeConPasos(SERVO3, 32, 90);
        alcanzarHomeConPasos(SERVO4, 25, 90);
        alcanzarHomeConPasos(SERVO5, 22, 90);

        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);

        firstPress = false;
        esperarPausaYDelay(espera);
      }

      ejecutarSecuencia();

      // Resetear estado del botón para el siguiente ciclo
      currentStartState = digitalRead(START_BUTTON_PIN);
      Serial.println("Listo. Esperando nuevo pulso en D19...");
    }
  }

  lastStartState = currentStartState;
  delay(20);
}
