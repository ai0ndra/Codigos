#include <ServoEasing.hpp>

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

// VELOCIDAD para el movimiento normal (Grados por segundo)
int velocidad = 30;
int espera    = 1000;

// Configuración del botón
const int BUTTON_PIN = 19; // Puede ser el pin 19 o 21. Conectar botón entre el pin y GND.
bool firstPress = true;

// Función para alcanzar la posición inicial usando "pasos" manuales (Seguridad)
// Se usa en la primera pulsación para evitar movimientos bruscos al arrancar.
void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino) {
  servo.attach(pin);
  // Forzamos un inicio en 45 grados para garantizar un movimiento lento y visible hasta 90.
  // Esto es necesario porque el ESP32 no conoce la posición física real al encenderse.
  for (int p = 45; p <= destino; p++) {
    servo.write(p);
    delay(40); // 40ms por grado = movimiento fluido
  }
}

void setup() {
  Serial.begin(115200);

  // IMPORTANTE para estabilidad en algunos ESP32
  // ServoEasing::setServoEasingCount(5);

  // Configurar el pin del botón con resistencia pull-up interna
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  Serial.println("Brazo Robot Listo.");
  Serial.println("Esperando pulsacion del boton para comenzar...");
}

void ejecutarSecuencia() {
  Serial.println("Ejecutando secuencia de trabajo...");

  // -------- SECUENCIA 1: IR A HOME (90) --------
  // Movimiento coordinado de todos los servos a la vez
  SERVO1.easeTo(90, velocidad);
  SERVO2.easeTo(90, velocidad);
  SERVO3.easeTo(90, velocidad);
  SERVO4.easeTo(90, velocidad);
  SERVO5.easeTo(90, velocidad);

  // Esperar a que todos los servos terminen antes de continuar
  ServoEasing::synchronizeAllServosStartAndWaitForAllServosToStop();
  delay(espera);

  // -------- SECUENCIA 2: IR A TRABAJO --------
  SERVO1.easeTo(60, velocidad);
  SERVO4.easeTo(125, velocidad);
  SERVO3.easeTo(55, velocidad);
  SERVO2.easeTo(125, velocidad);
  SERVO5.easeTo(45, velocidad); 

  ServoEasing::synchronizeAllServosStartAndWaitForAllServosToStop();
  delay(espera);
  
  SERVO2.easeTo(80, velocidad);
  SERVO4.easeTo(90, velocidad);

  ServoEasing::synchronizeAllServosStartAndWaitForAllServosToStop();
  delay(espera);
  
  SERVO1.easeTo(90, velocidad);
  SERVO2.easeTo(95, velocidad);
  SERVO3.easeTo(90, velocidad);
  SERVO4.easeTo(60, velocidad);
  SERVO5.easeTo(90, velocidad);

  ServoEasing::synchronizeAllServosStartAndWaitForAllServosToStop();
  delay(espera);

  Serial.println("Secuencia finalizada. Sistema detenido.");
}

void loop() {
  // Detectar si el botón ha sido presionado (LOW activo por INPUT_PULLUP)
  if (digitalRead(BUTTON_PIN) == LOW) {
    delay(50); // Pequeño delay para evitar rebotes (debounce)
    if (digitalRead(BUTTON_PIN) == LOW) {

      // Lógica de la PRIMERA pulsación (Homing secuencial lento)
      if (firstPress) {
        Serial.println("Primera pulsacion detectada: Realizando Homing de seguridad...");

        alcanzarHomeConPasos(SERVO1, 23, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO2, 33, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO3, 32, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO4, 25, 90);
        delay(500);
        alcanzarHomeConPasos(SERVO5, 22, 90);
        delay(500);

        // Configuramos el tipo de suavizado (Easing) para los movimientos futuros
        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);

        firstPress = false; // Marcamos que el inicio de seguridad ya se completó
        delay(espera);
      }

      // Ejecutar la secuencia de movimientos
      ejecutarSecuencia();

      Serial.println("Esperando nueva pulsacion para repetir la secuencia...");

      // Bloqueo para esperar a que el usuario suelte el botón
      while (digitalRead(BUTTON_PIN) == LOW) {
        delay(10);
      }
    }
  }
}
