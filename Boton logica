#include <ServoEasing.hpp>

// ===================== CONFIGURACIÓN DE PINES =====================
// BOTONES (Lógica Active-HIGH: 3.3V al pulsar, Resistencia a GND)
#define START_BUTTON_PIN 2
#define PAUSE_SWITCH_PIN 4
#define STATUS_LED_PIN 13

// SERVOS (Tus pines originales de hardware)
#define S1_PIN 23
#define S2_PIN 33
#define S3_PIN 32
#define S4_PIN 25
#define S5_PIN 22

// ===================== VARIABLES GLOBALES =====================
ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

int velocidadNormal = 30; // Grados por segundo (suave)
int velocidadLenta  = 15; // Para movimientos que quieras más naturales
int esperaCorta     = 1000;
int esperaLarga     = 2000;

bool firstPress = true;
int lastStartState = LOW;
bool isPaused = false;

// Variables para LED "Heartbeat" (Sin bloqueos)
unsigned long prevMillisLED = 0;
const long intervalLED = 500;
bool ledState = LOW;

// ===================== FUNCIONES DE APOYO =====================

// Parpadeo del LED azul para confirmar que el ESP32 no se ha congelado
void refrescarSistema() {
  unsigned long currentMillis = millis();
  if (currentMillis - prevMillisLED >= intervalLED) {
    prevMillisLED = currentMillis;
    ledState = !ledState;
    digitalWrite(STATUS_LED_PIN, ledState);
  }
}

// Detiene todo de inmediato si el interruptor de pausa (Pin 4) está en HIGH
void verificarPausa() {
  if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) {
    if (!isPaused) {
      Serial.println(">>> PAUSA ACTIVADA.");
      SERVO1.stop(); SERVO2.stop(); SERVO3.stop(); SERVO4.stop(); SERVO5.stop();
      digitalWrite(STATUS_LED_PIN, HIGH); // LED fijo durante pausa
      isPaused = true;
    }

    // Bloqueo total mientras el interruptor esté en HIGH
    while (digitalRead(PAUSE_SWITCH_PIN) == HIGH) {
      delay(10);
      refrescarSistema();
    }

    if (isPaused) {
      Serial.println(">>> REANUDANDO...");
      isPaused = false;
    }
  }
}

// Mueve un servo a su destino con control de pausa y suavizado
void moverServo(ServoEasing &s, int target, int vel, const char* name) {
  Serial.print("Moviendo "); Serial.print(name); Serial.print(" a "); Serial.println(target);

  // Mientras no haya llegado (tolerancia de 1 grado para evitar jitter)
  while (abs(s.getCurrentAngle() - target) > 1) {
    verificarPausa();
    refrescarSistema();

    s.startEaseTo(target, vel);
    delay(100); // Pequeña espera para estabilizar el consumo eléctrico

    while (s.isMoving()) {
      refrescarSistema();
      if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) {
        verificarPausa();
        // Al reanudar, salimos de este bucle para re-calcular la trayectoria
        break;
      }
      delay(10);
    }

    // Si terminó y no estamos pausados, verificamos llegada real
    if (!isPaused && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
}

// Espera sin bloquear el botón de pausa ni el LED parpadeante
void esperar(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarPausa();
    refrescarSistema();
    delay(10);
  }
}

// ===================== SECUENCIA DE TRABAJO (Tu orden exacto) =====================
void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia de trabajo...");

  // --- PARTE 1: Posicionamiento inicial de trabajo ---
  // Orden exacto: 1, 4, 3, 2, 5
  moverServo(SERVO1, 56,  velocidadLenta,  "S1");
  moverServo(SERVO4, 145, velocidadNormal, "S4");
  moverServo(SERVO3, 60,  velocidadNormal, "S3");
  moverServo(SERVO2, 125, velocidadNormal, "S2");
  moverServo(SERVO5, 43,  velocidadNormal, "S5");
  esperar(esperaCorta);

  // --- PARTE 2: Movimientos intermedios ---
  // Orden exacto: 2, luego 4
  moverServo(SERVO2, 100, velocidadLenta,  "S2");
  moverServo(SERVO4, 90,  velocidadNormal, "S4");
  esperar(esperaCorta);

  // --- PARTE 3: Movimientos finales ---
  // Orden exacto: 1, 4, 3, 2, 5
  moverServo(SERVO1, 135, velocidadLenta,  "S1");
  moverServo(SERVO4, 90,  velocidadNormal, "S4");
  moverServo(SERVO3, 65,  velocidadNormal, "S3");
  moverServo(SERVO2, 115, velocidadNormal, "S2");
  moverServo(SERVO5, 130, velocidadNormal, "S5");
  esperar(esperaLarga);

  Serial.println(">>> SECUENCIA COMPLETADA CON EXITO <<<");
}

// ===================== CONFIGURACIÓN INICIAL =====================
void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n--- BRAZO ROBOT: SISTEMA REINICIADO ---");

  // Configuración de botones y LED
  pinMode(START_BUTTON_PIN, INPUT); // Resistencia externa a GND (Active-HIGH)
  pinMode(PAUSE_SWITCH_PIN, INPUT);
  pinMode(STATUS_LED_PIN, OUTPUT);

  // Señal visual de arranque (Blink rápido)
  for(int i=0; i<3; i++) {
    digitalWrite(STATUS_LED_PIN, HIGH); delay(100);
    digitalWrite(STATUS_LED_PIN, LOW);  delay(100);
  }

  Serial.println("Esperando boton START (Pin 2) para comenzar...");
}

// ===================== BUCLE PRINCIPAL =====================
void loop() {
  refrescarSistema(); // El LED parpadea mientras espera
  verificarPausa();   // Permite pausar antes de empezar

  int currentState = digitalRead(START_BUTTON_PIN);

  // Detectar pulsación (De LOW a HIGH)
  if (currentState == HIGH && lastStartState == LOW) {
    delay(150); // Debounce fuerte para evitar arranques falsos
    if (digitalRead(START_BUTTON_PIN) == HIGH) {

      Serial.println(">>> BOTON START DETECTADO. PROCESANDO...");

      // --- HOMING DE SEGURIDAD (Solo la primera vez que se enciende) ---
      if (firstPress) {
        Serial.println("Realizando Homing inicial lento y suave...");

        // Attach uno por uno con movimiento inicial lento
        SERVO1.attach(S1_PIN); moverServo(SERVO1, 90, 10, "S1 (HOME)");
        SERVO2.attach(S2_PIN); moverServo(SERVO2, 90, 10, "S2 (HOME)");
        SERVO3.attach(S3_PIN); moverServo(SERVO3, 90, 10, "S3 (HOME)");
        SERVO4.attach(S4_PIN); moverServo(SERVO4, 90, 10, "S4 (HOME)");
        SERVO5.attach(S5_PIN); moverServo(SERVO5, 90, 10, "S5 (HOME)");

        // Configurar suavizado (Cubic) para todos los movimientos futuros
        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);

        firstPress = false;
        esperar(esperaCorta);
      }

      // Ejecutar la secuencia de trabajo solicitada
      ejecutarSecuencia();

      // Esperar a que suelte el botón para evitar reinicios accidentales
      while(digitalRead(START_BUTTON_PIN) == HIGH) {
        delay(10);
        refrescarSistema();
      }
      currentState = LOW;
    }
  }

  lastStartState = currentState;
  delay(20);
}
