#include <ServoEasing.hpp>

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

// ===================== PINES (Según tu código original) =====================
#define START_BUTTON_PIN 2   // Botón de Inicio
#define PAUSE_SWITCH_PIN 4   // Interruptor de Pausa
#define LED_PIN 13           // LED indicador

// ===================== VARIABLES =====================
bool firstPress = true;
int lastStartState = LOW;
int velocidad = 30; // Velocidad suave para evitar picos de corriente (Brownouts)
int espera = 1000;

// Variables para el LED parpadeante (SIN BLOQUEO)
unsigned long prevMillisLED = 0;
const long intervalLED = 500;
bool ledState = LOW;

// ===================== FUNCIONES DE APOYO =====================

// Parpadeo suave para saber si el ESP32 está vivo
void refrescarSistema() {
  unsigned long currentMillis = millis();
  if (currentMillis - prevMillisLED >= intervalLED) {
    prevMillisLED = currentMillis;
    ledState = !ledState;
    digitalWrite(LED_PIN, ledState);
  }
}

// Verifica la pausa (Si el Pin 4 está en HIGH, bloqueamos hasta que baje)
void verificarPausa() {
  if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) {
    Serial.println(">>> PAUSA ACTIVADA.");
    SERVO1.stop(); SERVO2.stop(); SERVO3.stop(); SERVO4.stop(); SERVO5.stop();
    digitalWrite(LED_PIN, HIGH); // LED fijo en pausa

    while (digitalRead(PAUSE_SWITCH_PIN) == HIGH) {
      delay(10);
      refrescarSistema();
    }
    Serial.println(">>> REANUDANDO...");
  }
}

// Función para mover un servo de forma controlada y pausable
void moverUnServo(ServoEasing &s, int target, const char* name) {
  Serial.print("Moviendo "); Serial.print(name); Serial.print(" a "); Serial.println(target);

  while (abs(s.getCurrentAngle() - target) > 1) {
    verificarPausa();
    refrescarSistema();

    s.startEaseTo(target, velocidad);
    delay(100); // Pequeña espera para estabilizar el consumo eléctrico

    while (s.isMoving()) {
      refrescarSistema();
      if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) {
        verificarPausa();
        break; // Salir para recalcular la ruta al reanudar
      }
      delay(10);
    }

    if (digitalRead(PAUSE_SWITCH_PIN) == LOW && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
}

void esperarPausaYDelay(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarPausa();
    refrescarSistema();
    delay(10);
  }
}

// ===================== SECUENCIA DE TRABAJO =====================
void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia de trabajo...");

  // SECUENCIA ORIGINAL: 1, 4, 3, 2, 5
  moverUnServo(SERVO1, 56, "S1");
  moverUnServo(SERVO4, 145, "S4");
  moverUnServo(SERVO3, 60, "S3");
  moverUnServo(SERVO2, 125, "S2");
  moverUnServo(SERVO5, 43, "S5");
  esperarPausaYDelay(espera);

  // MOVIMIENTO 2: S2(100), S4(90)
  moverUnServo(SERVO2, 100, "S2");
  moverUnServo(SERVO4, 90, "S4");
  esperarPausaYDelay(espera);

  // MOVIMIENTO 3: S1(135), S4(90), S3(65), S2(115), S5(130)
  moverUnServo(SERVO1, 135, "S1");
  moverUnServo(SERVO4, 90, "S4");
  moverUnServo(SERVO3, 65, "S3");
  moverUnServo(SERVO2, 115, "S2");
  moverUnServo(SERVO5, 130, "S5");
  esperarPausaYDelay(espera);

  Serial.println(">>> Secuencia terminada.");
}

// ===================== SETUP =====================
void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n--- SISTEMA REINICIADO ---");

  pinMode(START_BUTTON_PIN, INPUT);
  pinMode(PAUSE_SWITCH_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);

  // Pequeña señal de vida
  digitalWrite(LED_PIN, HIGH); delay(200);
  digitalWrite(LED_PIN, LOW);  delay(200);

  Serial.println("Brazo Robot Listo. Esperando botón...");
}

// ===================== LOOP =====================
void loop() {
  refrescarSistema();
  verificarPausa();

  int currentState = digitalRead(START_BUTTON_PIN);

  // Detectar flanco de subida (De LOW a HIGH)
  if (currentState == HIGH && lastStartState == LOW) {
    delay(100); // Debounce fuerte
    if (digitalRead(START_BUTTON_PIN) == HIGH) {
      Serial.println(">>> Botón presionado. Iniciando...");

      if (firstPress) {
        Serial.println("Homing de seguridad...");
        // S1:23, S2:33, S3:32, S4:25, S5:22
        // IMPORTANTE: Primero attach() y luego moverUnServo()
        SERVO1.attach(23); moverUnServo(SERVO1, 90, "S1");
        SERVO2.attach(33); moverUnServo(SERVO2, 90, "S2");
        SERVO3.attach(32); moverUnServo(SERVO3, 90, "S3");
        SERVO4.attach(25); moverUnServo(SERVO4, 90, "S4");
        SERVO5.attach(22); moverUnServo(SERVO5, 90, "S5");

        // Suavizado de movimientos
        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);

        firstPress = false;
        esperarPausaYDelay(espera);
      }

      ejecutarSecuencia();

      // Bloquear hasta soltar el botón
      while(digitalRead(START_BUTTON_PIN) == HIGH) {
        delay(10);
        refrescarSistema();
      }
      currentState = LOW;
    }
  }

  lastStartState = currentState;
  delay(20);
}
