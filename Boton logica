#include <ServoEasing.hpp>

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

// VELOCIDAD para el movimiento normal (Grados por segundo)
int velocidad = 30;
int espera    = 1000;

// Configuración de los botones (Nuevos pines para evitar conflictos con SPI/I2C)
const int START_BUTTON_PIN = 26; // Botón momentáneo para Iniciar (Conectar a D26 y al Pin 14)
const int PAUSE_SWITCH_PIN = 27; // Interruptor sostenido para Pausar (Conectar a D27 y al Pin 14)
const int VIRTUAL_GND_PIN  = 14; // Pin que actuará como TIERRA física (LOW) para los botones
const int BLUE_LED_PIN     = 2;  // LED azul interno del ESP32

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;

// Variables para el parpadeo del LED (Sin bloqueo)
unsigned long previousMillisLED = 0;
const long intervalLED = 500; // Parpadeo cada 500ms
bool ledState = LOW;

// Función para parpadear el LED azul sin detener el código
void actualizarLED() {
  unsigned long currentMillis = millis();
  if (currentMillis - previousMillisLED >= intervalLED) {
    previousMillisLED = currentMillis;
    ledState = !ledState;
    digitalWrite(BLUE_LED_PIN, ledState);
  }
}

// Función para alcanzar la posición inicial usando "pasos" manuales (Seguridad)
void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino) {
  servo.attach(pin);
  for (int p = 45; p <= destino; p++) {
    actualizarLED(); // Mantener el LED parpadeando mientras se mueve
    servo.write(p);
    delay(40);
  }
}

// Verifica el interruptor de pausa y detiene el movimiento FISICAMENTE de inmediato
void verificarBotonPausa() {
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    delay(200); // Debounce fuerte para filtrar ruido de los motores
    if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) return;

    if (!isPaused) {
      Serial.println(">>> PAUSA ACTIVADA.");
      SERVO1.stop();
      SERVO2.stop();
      SERVO3.stop();
      SERVO4.stop();
      SERVO5.stop();
      isPaused = true;
      digitalWrite(BLUE_LED_PIN, HIGH); // LED fijo durante la pausa
    }

    // Mientras el interruptor siga cerrado (LOW), bloqueamos aquí
    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      delay(50);
    }

    if (isPaused) {
      Serial.println(">>> REANUDANDO...");
      isPaused = false;
    }
  }
}

// Función para mover UN SOLO SERVO de forma secuencial y con detección de pausa REANUDABLE
void moverUnServo(ServoEasing &s, int target, const char* name) {
  Serial.print("Moviendo "); Serial.print(name); Serial.print(" a "); Serial.println(target);

  while (abs(s.getCurrentAngle() - target) > 1) {
    verificarBotonPausa();
    actualizarLED(); // El LED sigue parpadeando durante el movimiento
   
    s.startEaseTo(target, velocidad);
    delay(100); // Estabilizacion
   
    while (s.isMoving()) {
      actualizarLED();
      if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
        verificarBotonPausa();
        break;
      }
      delay(10);
    }
   
    if (!isPaused && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
  Serial.print(name); Serial.println(" OK.");
}

// Función para esperar un tiempo (delay) sin bloquear el interruptor de pausa ni el LED
void esperarPausaYDelay(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarBotonPausa();
    actualizarLED();
    delay(10);
  }
}

void setup() {
  Serial.begin(115200);

  // Configuración de la TIERRA VIRTUAL (Pin 14) para que los botones tengan GND sólido
  pinMode(VIRTUAL_GND_PIN, OUTPUT);
  digitalWrite(VIRTUAL_GND_PIN, LOW); // Este pin ahora es 0V (GND)

  // LED azul interno
  pinMode(BLUE_LED_PIN, OUTPUT);

  // Configuración de pines de entrada con Pull-up interno
  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);
 
  delay(1000);
  Serial.println("\n--- SISTEMA REINICIADO ---");

  // SEÑAL VISUAL: Pequeño movimiento del primer servo para avisar que está encendido
  SERVO1.attach(23);
  SERVO1.write(95); delay(300);
  SERVO1.write(90); delay(300);

  lastStartState = digitalRead(START_BUTTON_PIN);
  Serial.println("Brazo Robot Listo. Use el Pin 14 como Tierra para los botones.");
}

void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia de trabajo...");

  // -------- SECUENCIA 1: IR A HOME (90) --------
  moverUnServo(SERVO1, 90, "S1");
  moverUnServo(SERVO2, 90, "S2");
  moverUnServo(SERVO3, 90, "S3");
  moverUnServo(SERVO4, 90, "S4");
  moverUnServo(SERVO5, 90, "S5");
  esperarPausaYDelay(espera);

  // -------- SECUENCIA 2: IR A TRABAJO --------
  moverUnServo(SERVO1, 56, "S1");
  moverUnServo(SERVO4, 120, "S4");
  moverUnServo(SERVO3, 55, "S3");
  moverUnServo(SERVO2, 125, "S2");
  moverUnServo(SERVO5, 45, "S5");
  esperarPausaYDelay(espera);
 
  // PARTE 2: 2(80), luego 4(90)
  moverUnServo(SERVO2, 80, "S2");
  moverUnServo(SERVO4, 90, "S4");
  esperarPausaYDelay(espera);
 
  // PARTE 3: 1(135), 4(90), 3(55), 2(120), 5(45)
  moverUnServo(SERVO1, 135, "S1");
  moverUnServo(SERVO4, 90, "S4");
  moverUnServo(SERVO3, 55, "S3");
  moverUnServo(SERVO2, 120, "S2");
  moverUnServo(SERVO5, 45, "S5");
  esperarPausaYDelay(espera);
 
  Serial.println(">>> SECUENCIA FINALIZADA <<<");
}

void loop() {
  actualizarLED(); // El LED parpadea mientras espera el botón

  // Vigilancia constante de la pausa
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    verificarBotonPausa();
    return;
  }

  int currentStartState = digitalRead(START_BUTTON_PIN);

  // Detectar pulsación (De HIGH a LOW)
  if (currentStartState == LOW && lastStartState == HIGH) {
    delay(100); // Debounce
    if (digitalRead(START_BUTTON_PIN) == LOW) {
      Serial.println(">>> Boton INICIO detectado.");

      if (firstPress) {
        Serial.println("Realizando Homing inicial de seguridad...");
        alcanzarHomeConPasos(SERVO1, 23, 90);
        alcanzarHomeConPasos(SERVO2, 33, 90);
        alcanzarHomeConPasos(SERVO3, 32, 90);
        alcanzarHomeConPasos(SERVO4, 25, 90);
        alcanzarHomeConPasos(SERVO5, 22, 90);

        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);
       
        firstPress = false;
        esperarPausaYDelay(espera);
      }

      ejecutarSecuencia();

      // Bloquear hasta que suelten el boton
      while(digitalRead(START_BUTTON_PIN) == LOW) { delay(10); actualizarLED(); }
      currentStartState = HIGH;
    }
  }

  lastStartState = currentStartState;
  delay(20);
}
