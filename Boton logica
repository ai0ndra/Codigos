#include <ServoEasing.hpp>


ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;


// VELOCIDAD para el movimiento normal (Grados por segundo)
int velocidad = 30;
int espera    = 1000;


// Configuración de los botones (IMPORTANTE: Conectar ambos a un pin GND físico)
const int START_BUTTON_PIN = 19; // Botón momentáneo para Iniciar (D19 a GND)
const int PAUSE_SWITCH_PIN = 21; // Interruptor sostenido (Switch) para Pausar (D21 a GND)


bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;


// Función para alcanzar la posición inicial usando "pasos" manuales (Seguridad)
void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino) {
  servo.attach(pin);
  for (int p = 45; p <= destino; p++) {
    servo.write(p);
    delay(40);
  }
}


// Verifica el interruptor de pausa y detiene el movimiento FISICAMENTE de inmediato
void verificarBotonPausa() {
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    if (!isPaused) {
      Serial.println("PAUSA ACTIVADA.");
      SERVO1.stop();
      SERVO2.stop();
      SERVO3.stop();
      SERVO4.stop();
      SERVO5.stop();
      isPaused = true;
    }


    // Mientras el interruptor siga cerrado, bloqueamos aquí
    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      delay(50);
    }


    if (isPaused) {
      Serial.println("REANUDANDO...");
      isPaused = false;
    }
  }
}


// Función para mover UN SOLO SERVO de forma secuencial y con detección de pausa REANUDABLE
void moverUnServo(ServoEasing &s, int target) {
  // Mientras el servo no haya llegado a su destino
  while (s.getCurrentAngle() != target) {
   
    // Iniciar o continuar movimiento hacia el objetivo
    s.startEaseTo(target, velocidad);
   
    // Mientras se esté moviendo hacia el objetivo
    while (s.isMoving()) {
      if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
        verificarBotonPausa();
        // Si pausamos, salimos de este bucle interno para re-evaluar la posición al reanudar
        break;
      }
      delay(10);
    }
   
    // Si terminó de moverse y no estamos en pausa, verificamos si llegó al destino real
    if (!isPaused && !s.isMoving()) {
      // Si el ángulo actual es el objetivo (o muy cerca), salimos del bucle principal
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
}


// Función para esperar un tiempo (delay) sin bloquear el interruptor de pausa
void esperarPausaYDelay(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarBotonPausa();
    delay(10);
  }
}


void setup() {
  Serial.begin(115200);
 
  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);
 
  delay(100);
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    Serial.println(">>> AVISO: El interruptor de PAUSA esta CERRADO.");
  }


  lastStartState = digitalRead(START_BUTTON_PIN);
  Serial.println("Brazo Robot Listo.");
}


void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia SECUENCIAL...");


  // -------- SECUENCIA 1: IR A HOME (90) --------
  // Orden original: 1, 2, 3, 4, 5
  moverUnServo(SERVO1, 90);
  moverUnServo(SERVO2, 90);
  moverUnServo(SERVO3, 90);
  moverUnServo(SERVO4, 90);
  moverUnServo(SERVO5, 90);
  esperarPausaYDelay(espera);


  // -------- SECUENCIA 2: IR A TRABAJO (Orden original exacto: 1, 4, 3, 2, 5) --------
  moverUnServo(SERVO1, 56);//55
  moverUnServo(SERVO4, 120);
  moverUnServo(SERVO3, 55);
  moverUnServo(SERVO2, 125);
  moverUnServo(SERVO5, 45);
  esperarPausaYDelay(espera);
 
  // PARTE 2: 2(80), luego 4(90)
  moverUnServo(SERVO2, 80);
  moverUnServo(SERVO4, 90);
  esperarPausaYDelay(espera);
 
  // PARTE 3: 1(90), 2(95), 3(90), 4(60), 5(90)
  moverUnServo(SERVO1, 135);//70
  moverUnServo(SERVO4, 90);//95
  moverUnServo(SERVO3, 55); //60
  moverUnServo(SERVO2, 120); //120
  moverUnServo(SERVO5, 45);
  esperarPausaYDelay(espera);
 
  Serial.println("Secuencia finalizada.");
}


void loop() {
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    verificarBotonPausa();
    return;
  }


  int currentStartState = digitalRead(START_BUTTON_PIN);


  if (currentStartState == LOW && lastStartState == HIGH) {
    delay(50);
    if (digitalRead(START_BUTTON_PIN) == LOW) {
      if (firstPress) {
        Serial.println("Realizando Homing de seguridad...");
        alcanzarHomeConPasos(SERVO1, 23, 90);
        alcanzarHomeConPasos(SERVO2, 33, 90);
        alcanzarHomeConPasos(SERVO3, 32, 90);
        alcanzarHomeConPasos(SERVO4, 25, 90);
        alcanzarHomeConPasos(SERVO5, 22, 90);


        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);
       
        firstPress = false;
        esperarPausaYDelay(espera);
      }


      ejecutarSecuencia();
      currentStartState = digitalRead(START_BUTTON_PIN);
    }
  }


  lastStartState = currentStartState;
  delay(20);
}
