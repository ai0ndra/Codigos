#include <ServoEasing.hpp>

ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

// VELOCIDAD para el movimiento normal (Grados por segundo)
int velocidad = 30;
int espera    = 1000;

// Configuración de los botones (IMPORTANTE: Conectar ambos a un pin GND físico)
const int START_BUTTON_PIN = 19; // Botón momentáneo para Iniciar (D19 a GND)
const int PAUSE_SWITCH_PIN = 21; // Interruptor sostenido (Switch) para Pausar (D21 a GND)

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;

// Función para alcanzar la posición inicial usando "pasos" manuales (Seguridad)
void alcanzarHomeConPasos(ServoEasing &servo, int pin, int destino) {
  servo.attach(pin);
  for (int p = 45; p <= destino; p++) {
    servo.write(p);
    delay(40);
  }
}

// Verifica el interruptor de pausa y detiene el movimiento FISICAMENTE de inmediato
void verificarBotonPausa() {
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    delay(150); // Debounce fuerte para evitar paradas falsas por ruido electrico
    if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) return; // Si fue un pico corto, ignorar

    if (!isPaused) {
      Serial.println(">>> PAUSA ACTIVADA.");
      SERVO1.stop();
      SERVO2.stop();
      SERVO3.stop();
      SERVO4.stop();
      SERVO5.stop();
      isPaused = true;
    }

    // Mientras el interruptor siga cerrado, bloqueamos aquí
    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      delay(50);
    }

    if (isPaused) {
      Serial.println(">>> REANUDANDO...");
      isPaused = false;
    }
  }
}

// Función para mover UN SOLO SERVO de forma secuencial y con detección de pausa REANUDABLE
void moverUnServo(ServoEasing &s, int target, const char* name) {
  Serial.print("Moviendo "); Serial.print(name); Serial.print(" a "); Serial.println(target);

  // Mientras el servo no haya llegado a su destino (usamos abs para evitar problemas de precision)
  while (abs(s.getCurrentAngle() - target) > 1) {

    verificarBotonPausa();
   
    // Iniciar o continuar movimiento hacia el objetivo
    s.startEaseTo(target, velocidad);
    delay(100); // Estabilizacion para que la libreria registre el movimiento y evitar picos
   
    // Mientras se esté moviendo hacia el objetivo
    while (s.isMoving()) {
      if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
        verificarBotonPausa();
        // Si pausamos, salimos de este bucle interno para re-evaluar la posición al reanudar
        break;
      }
      delay(10);
    }
   
    // Si terminó de moverse y no estamos en pausa, verificamos si llegó al destino real
    if (!isPaused && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
  Serial.print(name); Serial.println(" OK.");
}

// Función para esperar un tiempo (delay) sin bloquear el interruptor de pausa
void esperarPausaYDelay(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarBotonPausa();
    delay(10);
  }
}

void setup() {
  Serial.begin(115200);

  // Configuración de pines (INPUT_PULLUP asegura que esten en HIGH si no se pulsan)
  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);
 
  delay(500);
  Serial.println("\n--- SISTEMA REINICIADO ---");

  // Diagnóstico de hardware (Para verificar si los pines están en LOW por error)
  Serial.print("Estado Pin Inicio (19): "); Serial.println(digitalRead(START_BUTTON_PIN) == LOW ? "PULSADO (LOW)" : "LIBRE (HIGH)");
  Serial.print("Estado Pin Pausa (21): "); Serial.println(digitalRead(PAUSE_SWITCH_PIN) == LOW ? "CERRADO (LOW)" : "ABIERTO (HIGH)");

  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    Serial.println(">>> AVISO: El interruptor de PAUSA esta detectado como CERRADO.");
  }

  // Inicialización del estado del botón para detectar el flanco de bajada
  lastStartState = digitalRead(START_BUTTON_PIN);
  Serial.println("Brazo Robot Listo. Pulse START para comenzar.");
}

void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia de trabajo...");

  // -------- SECUENCIA 1: IR A HOME (90) --------
  moverUnServo(SERVO1, 90, "S1");
  moverUnServo(SERVO2, 90, "S2");
  moverUnServo(SERVO3, 90, "S3");
  moverUnServo(SERVO4, 90, "S4");
  moverUnServo(SERVO5, 90, "S5");
  esperarPausaYDelay(espera);

  // -------- SECUENCIA 2: IR A TRABAJO --------
  moverUnServo(SERVO1, 56, "S1");
  moverUnServo(SERVO4, 120, "S4");
  moverUnServo(SERVO3, 55, "S3");
  moverUnServo(SERVO2, 125, "S2");
  moverUnServo(SERVO5, 45, "S5");
  esperarPausaYDelay(espera);
 
  // PARTE 2: 2(80), luego 4(90)
  moverUnServo(SERVO2, 80, "S2");
  moverUnServo(SERVO4, 90, "S4");
  esperarPausaYDelay(espera);
 
  // PARTE 3: 1(135), 4(90), 3(55), 2(120), 5(45)
  moverUnServo(SERVO1, 135, "S1");
  moverUnServo(SERVO4, 90, "S4");
  moverUnServo(SERVO3, 55, "S3");
  moverUnServo(SERVO2, 120, "S2");
  moverUnServo(SERVO5, 45, "S5");
  esperarPausaYDelay(espera);
 
  Serial.println(">>> SECUENCIA FINALIZADA CON EXITO <<<");
}

void loop() {
  // Vigilancia constante de la pausa (Si esta LOW, bloqueamos todo)
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    // Si el usuario intenta arrancar mientras esta en PAUSA, avisamos por Serial
    if (digitalRead(START_BUTTON_PIN) == LOW && lastStartState == HIGH) {
      Serial.println(">>> ERROR: No se puede iniciar porque la PAUSA (Pin 21) esta ACTIVADA.");
      delay(500);
    }
    verificarBotonPausa();
    return;
  }

  int currentStartState = digitalRead(START_BUTTON_PIN);

  // Detectar pulsación (De HIGH a LOW)
  if (currentStartState == LOW && lastStartState == HIGH) {
    delay(100); // Debounce
    if (digitalRead(START_BUTTON_PIN) == LOW) {
      Serial.println(">>> Boton de INICIO detectado. Procesando...");

      if (firstPress) {
        Serial.println("Realizando Homing inicial lento...");
        alcanzarHomeConPasos(SERVO1, 23, 90);
        alcanzarHomeConPasos(SERVO2, 33, 90);
        alcanzarHomeConPasos(SERVO3, 32, 90);
        alcanzarHomeConPasos(SERVO4, 25, 90);
        alcanzarHomeConPasos(SERVO5, 22, 90);

        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);
       
        firstPress = false;
        esperarPausaYDelay(espera);
      }

      ejecutarSecuencia();

      // Esperar a que suelten el boton para evitar que reinicie solo
      while(digitalRead(START_BUTTON_PIN) == LOW) { delay(10); }
      currentStartState = HIGH; // Forzar estado HIGH tras soltar
    }
  }

  lastStartState = currentStartState;
  delay(20);
}
