#include <ServoEasing.hpp>

// ===================== CONFIGURACIÓN DE PINES =====================
// BOTONES (Conectados a GND como indicó el usuario)
// Lógica Active-LOW (LOW = Pulsado)
#define START_BUTTON_PIN 2
#define PAUSE_SWITCH_PIN 4
#define STATUS_LED_PIN 13    // El usuario pidió el LED azul (normalmente pin 2), pero el botón ya usa el pin 2. Usaremos el 13 como en su código OG.

// SERVOS (Pines originales)
#define S1_PIN 23
#define S2_PIN 33
#define S3_PIN 32
#define S4_PIN 25
#define S5_PIN 22

// ===================== VARIABLES GLOBALES =====================
ServoEasing SERVO1;
ServoEasing SERVO2;
ServoEasing SERVO3;
ServoEasing SERVO4;
ServoEasing SERVO5;

int velocidadNormal = 30;
int velocidadLenta  = 15;
int esperaCorta     = 1000;
int esperaLarga     = 2000;

bool firstPress = true;
int lastStartState = HIGH; // Inicia en HIGH por el Pull-up
bool isPaused = false;

// Variables para LED Heartbeat
unsigned long prevMillisLED = 0;
const long intervalLED = 500;
bool ledState = LOW;

// ===================== FUNCIONES DE APOYO =====================

void refrescarSistema() {
  unsigned long currentMillis = millis();
  if (currentMillis - prevMillisLED >= intervalLED) {
    prevMillisLED = currentMillis;
    ledState = !ledState;
    digitalWrite(STATUS_LED_PIN, ledState);
  }
}

void verificarPausa() {
  // Lógica Active-LOW: LOW significa que el interruptor está cerrado (Pausado)
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    if (!isPaused) {
      Serial.println(">>> PAUSA ACTIVADA (PIN 4 EN LOW).");
      SERVO1.stop(); SERVO2.stop(); SERVO3.stop(); SERVO4.stop(); SERVO5.stop();
      digitalWrite(STATUS_LED_PIN, HIGH);
      isPaused = true;
    }

    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      delay(10);
      refrescarSistema();
    }

    if (isPaused) {
      Serial.println(">>> REANUDANDO...");
      isPaused = false;
    }
  }
}

void moverServo(ServoEasing &s, int target, int vel, const char* name) {
  Serial.print("Moviendo "); Serial.print(name); Serial.print(" a "); Serial.println(target);

  while (abs(s.getCurrentAngle() - target) > 1) {
    verificarPausa();
    refrescarSistema();

    s.startEaseTo(target, vel);
    delay(100);

    while (s.isMoving()) {
      refrescarSistema();
      if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
        verificarPausa();
        break;
      }
      delay(10);
    }

    if (digitalRead(PAUSE_SWITCH_PIN) == HIGH && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
}

void esperar(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarPausa();
    refrescarSistema();
    delay(10);
  }
}

// ===================== SECUENCIA DE TRABAJO =====================
void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia de trabajo...");

  // PARTE 1: 1, 4, 3, 2, 5
  moverServo(SERVO1, 56,  velocidadLenta,  "S1");
  moverServo(SERVO4, 145, velocidadNormal, "S4");
  moverServo(SERVO3, 60,  velocidadNormal, "S3");
  moverServo(SERVO2, 125, velocidadNormal, "S2");
  moverServo(SERVO5, 43,  velocidadNormal, "S5");
  esperar(esperaCorta);

  // PARTE 2: 2, 4
  moverServo(SERVO2, 100, velocidadLenta,  "S2");
  moverServo(SERVO4, 90,  velocidadNormal, "S4");
  esperar(esperaCorta);

  // PARTE 3: 1, 4, 3, 2, 5
  moverServo(SERVO1, 135, velocidadLenta,  "S1");
  moverServo(SERVO4, 90,  velocidadNormal, "S4");
  moverServo(SERVO3, 65,  velocidadNormal, "S3");
  moverServo(SERVO2, 115, velocidadNormal, "S2");
  moverServo(SERVO5, 130, velocidadNormal, "S5");
  esperar(esperaLarga);

  Serial.println(">>> SECUENCIA COMPLETADA <<<");
}

// ===================== SETUP =====================
void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n--- BRAZO ROBOT: SISTEMA REINICIADO ---");

  // Pines con INPUT_PULLUP (Botones a GND)
  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);
  pinMode(STATUS_LED_PIN, OUTPUT);

  for(int i=0; i<3; i++) {
    digitalWrite(STATUS_LED_PIN, HIGH); delay(100);
    digitalWrite(STATUS_LED_PIN, LOW);  delay(100);
  }

  Serial.println("Listo. Esperando boton START (Pin 2) para comenzar...");
}

// ===================== LOOP =====================
void loop() {
  refrescarSistema();
  verificarPausa();

  int currentState = digitalRead(START_BUTTON_PIN);

  // Detectar pulsación (De HIGH a LOW)
  if (currentState == LOW && lastStartState == HIGH) {
    delay(150); // Debounce
    if (digitalRead(START_BUTTON_PIN) == LOW) {

      Serial.println(">>> BOTON START DETECTADO.");

      if (firstPress) {
        Serial.println("Homing inicial lento...");

        SERVO1.attach(S1_PIN); moverServo(SERVO1, 90, 10, "S1");
        SERVO2.attach(S2_PIN); moverServo(SERVO2, 90, 10, "S2");
        SERVO3.attach(S3_PIN); moverServo(SERVO3, 90, 10, "S3");
        SERVO4.attach(S4_PIN); moverServo(SERVO4, 90, 10, "S4");
        SERVO5.attach(S5_PIN); moverServo(SERVO5, 90, 10, "S5");

        SERVO1.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO2.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO3.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO4.setEasingType(EASE_CUBIC_IN_OUT);
        SERVO5.setEasingType(EASE_CUBIC_IN_OUT);

        firstPress = false;
        esperar(esperaCorta);
      }

      ejecutarSecuencia();

      while(digitalRead(START_BUTTON_PIN) == LOW) {
        delay(10);
        refrescarSistema();
      }
      currentState = HIGH;
    }
  }

  lastStartState = currentState;
  delay(20);
}
