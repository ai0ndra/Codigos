#include <ServoEasing.hpp>

// ===================== PINES (Basados en el código OG del usuario) =====================
#define START_BUTTON_PIN 2   // Botón de Inicio (D2 a VCC con pull-down externo)
#define PAUSE_SWITCH_PIN 4   // Interruptor de Pausa (D4 a VCC con pull-down externo)
#define LED_AZUL 2            // ¡ATENCIÓN! El LED azul interno suele estar en el Pin 2
#define LED_OG 13             // LED original en pin 13

// Servos (Pins confirmados de memoria de hardware anterior)
const int S1_PIN = 23;
const int S2_PIN = 33;
const int S3_PIN = 32;
const int S4_PIN = 25;
const int S5_PIN = 22;

// ===================== VARIABLES [DIAGNÓSTICO DE VOLTAJE] =====================
// Esta variable sobrevive a los reinicios para avisarte si la fuente falla
RTC_DATA_ATTR int contadorReinicios = 0;

ServoEasing SERVO1, SERVO2, SERVO3, SERVO4, SERVO5;

bool firstPress = true;
int lastStartState = LOW;
bool isPaused = false;
int espera = 1000;
int velocidad = 30;

// Variables para LED no bloqueante
unsigned long lastBlinkTime = 0;
bool ledState = LOW;

// ===================== FUNCIONES DE APOYO =====================

void refrescarLED() {
  // Parpadeo cada 500ms sin detener el código
  if (millis() - lastBlinkTime >= 500) {
    lastBlinkTime = millis();
    ledState = !ledState;
    digitalWrite(LED_OG, ledState);

    // NOTA: Si el botón de inicio está en el Pin 2, el LED azul no parpadeará
    // correctamente porque comparten el mismo pin físico.
  }
}

void verificarPausa() {
  refrescarLED();
  // Lógica OG: HIGH es Pausa activa (Switch cerrado a VCC)
  if (digitalRead(PAUSE_SWITCH_PIN) == HIGH) {
    if (!isPaused) {
      Serial.println("⏸ PAUSA ACTIVADA");
      SERVO1.stop();
      SERVO2.stop();
      SERVO3.stop();
      SERVO4.stop();
      SERVO5.stop();
      isPaused = true;
    }

    while (digitalRead(PAUSE_SWITCH_PIN) == HIGH) {
      refrescarLED();
      delay(20);
    }

    if (isPaused) {
      Serial.println("▶ REANUDANDO...");
      isPaused = false;
    }
  }
}

/**
 * Mueve un solo servo suavemente (Easing) y espera a que termine.
 * Incluye una pequeña pausa extra para no saturar la fuente de alimentación.
 */
void moverUnServo(ServoEasing &s, int target, const char* nombre) {
  if (abs(s.getCurrentAngle() - target) <= 1) return;

  Serial.print("Moviendo "); Serial.print(nombre); Serial.print(" a "); Serial.println(target);

  while (abs(s.getCurrentAngle() - target) > 1) {
    verificarPausa();
    s.startEaseTo(target, velocidad);
    delay(50); // Estabilización

    while (s.isMoving()) {
      verificarPausa();
      delay(10);
    }

    if (!isPaused && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }

  // ⚡ MITIGACIÓN DE PICOS: Pausa de 150ms entre movimientos de servos
  delay(150);
}

void esperar(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarPausa();
    delay(10);
  }
}

void homingSeguro(ServoEasing &servo, int pin, int destino) {
  servo.attach(pin);
  Serial.print("Homing pin "); Serial.println(pin);
  for (int p = 45; p <= destino; p++) {
    verificarPausa();
    servo.write(p);
    delay(40);
  }
  servo.setEasingType(EASE_CUBIC_IN_OUT);
  delay(300); // Pausa para estabilizar voltaje tras el attach
}

// ===================== SECUENCIA DE TRABAJO =====================
void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia (Modo Seguro)...");

  moverUnServo(SERVO1, 56, "S1");
  moverUnServo(SERVO4, 145, "S4");
  moverUnServo(SERVO3, 60, "S3");
  moverUnServo(SERVO2, 125, "S2");
  moverUnServo(SERVO5, 43, "S5");
  esperar(espera);

  moverUnServo(SERVO2, 100, "S2");
  moverUnServo(SERVO4, 90, "S4");
  esperar(espera);

  moverUnServo(SERVO1, 135, "S1");
  moverUnServo(SERVO4, 90, "S4");
  moverUnServo(SERVO3, 65, "S3");
  moverUnServo(SERVO2, 115, "S2");
  moverUnServo(SERVO5, 130, "S5");
  esperar(espera);

  Serial.println(">>> SECUENCIA FINALIZADA <<<");
}

// ===================== SETUP =====================
void setup() {
  Serial.begin(115200);
  contadorReinicios++;

  pinMode(START_BUTTON_PIN, INPUT);
  pinMode(PAUSE_SWITCH_PIN, INPUT);
  pinMode(LED_OG, OUTPUT);

  delay(500);
  Serial.println("\n-----------------------------------");
  Serial.print("SISTEMA LISTO. Intento de inicio #"); Serial.println(contadorReinicios);
  if (contadorReinicios > 1) {
    Serial.println("¡OJO! El sistema se reinició solo. Revisa la fuente de poder.");
  }
  Serial.println("-----------------------------------");

  lastStartState = digitalRead(START_BUTTON_PIN);
}

// ===================== LOOP PRINCIPAL =====================
void loop() {
  // El LED parpadea y revisamos pausa continuamente
  verificarPausa();

  int currentState = digitalRead(START_BUTTON_PIN);

  // Detectar pulsación (Flanco de subida: LOW -> HIGH según código OG)
  if (currentState == HIGH && lastStartState == LOW) {
    delay(100); // Debounce fuerte

    if (digitalRead(START_BUTTON_PIN) == HIGH) {
      Serial.println(">>> BOTÓN PRESIONADO <<<");

      if (firstPress) {
        Serial.println("Realizando Homing Secuencial...");
        homingSeguro(SERVO1, S1_PIN, 90);
        homingSeguro(SERVO2, S2_PIN, 90);
        homingSeguro(SERVO3, S3_PIN, 90);
        homingSeguro(SERVO4, S4_PIN, 90);
        homingSeguro(SERVO5, S5_PIN, 90);
        firstPress = false;
        esperar(espera);
      }

      ejecutarSecuencia();

      // Esperar a que el usuario suelte el botón para evitar repeticiones
      while(digitalRead(START_BUTTON_PIN) == HIGH) {
        refrescarLED();
        delay(10);
      }
    }
  }

  lastStartState = currentState;
  delay(10);
}
