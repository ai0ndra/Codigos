#include <ESP32Servo.h>
#include <ServoEasing.hpp>

/**
 * 🤖 CÓDIGO FINAL BRAZO ROBÓTICO - VERSIÓN BOOT-AWARE (P2, P4, P13)
 *
 * Este código resuelve:
 * 1. Estado inicial del interruptor (Pin 4): Detecta si arranca "abierto" o "cerrado".
 * 2. LED 13 inteligente:
 *    - Fijo si arranca en Pausa.
 *    - Parpadea si arranca listo.
 * 3. Botón Start (Pin 2): Lógica Active Low (Ground al presionar).
 * 4. Reinicios/Brownouts: Encendido ultra-lento uno por uno.
 */

// ===================== CONFIGURACIÓN DE PINES (OG) =====================
const int PIN_START  = 2;   // Botón Start (Presionar = LOW / Tierra)
const int PIN_PAUSE  = 4;   // Interruptor Pausa (Cerrado = LOW / Tierra)
const int PIN_LED    = 13;  // LED de Estado

// Pines de los Servos (Confirmados)
const int PIN_S1 = 23;
const int PIN_S2 = 33;
const int PIN_S3 = 32;
const int PIN_S4 = 25;
const int PIN_S5 = 22;

// ===================== VARIABLES GLOBALES =====================
ServoEasing SERVO1, SERVO2, SERVO3, SERVO4, SERVO5;

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;

int globalSpeed = 30; // Velocidad para la secuencia normal
int globalWait  = 1000; // Un segundo de espera entre bloques

// Variables para parpadeo de LED (no bloqueante)
unsigned long lastBlinkTime = 0;
bool ledState = LOW;

// [DIAGNÓSTICO] Para detectar si el ESP32 se reinicia por falta de energía
RTC_DATA_ATTR int resetCounter = 0;

// ===================== FUNCIONES DE ESTADO =====================

/**
 * Mantiene el LED actualizado y revisa la pausa continuamente.
 */
void refreshSystem() {
  // 1. Detección de Pausa (LOW = Interruptor cerrado a Tierra)
  if (digitalRead(PIN_PAUSE) == LOW) {
    if (!isPaused) {
      Serial.println("⏸ PAUSA ACTIVADA");
      // Solo paramos los servos si ya fueron conectados (attach)
      if (!firstPress) {
        SERVO1.stop(); SERVO2.stop(); SERVO3.stop(); SERVO4.stop(); SERVO5.stop();
      }
      digitalWrite(PIN_LED, HIGH); // LED Fijo durante pausa
      isPaused = true;
    }

    // Bloqueo mientras el interruptor de pausa esté en LOW (Tierra)
    while (digitalRead(PIN_PAUSE) == LOW) {
      digitalWrite(PIN_LED, HIGH);
      delay(20);
    }

    if (isPaused) {
      Serial.println("▶ REANUDANDO...");
      isPaused = false;
    }
  }

  // 2. Parpadeo del LED (500ms) SOLO si no estamos en pausa
  if (!isPaused) {
    if (millis() - lastBlinkTime >= 500) {
      lastBlinkTime = millis();
      ledState = !ledState;
      digitalWrite(PIN_LED, ledState);
    }
  }
}

/**
 * Espera (delay) sin bloquear el LED ni la detección de pausa.
 */
void safeWait(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    refreshSystem();
    delay(10);
  }
}

// ===================== MOVIMIENTOS SEGUROS =====================

void moveServo(ServoEasing &s, int target, const char* name) {
  if (abs(s.getCurrentAngle() - target) <= 1) return;

  Serial.print("Moviendo "); Serial.print(name); Serial.print(" a "); Serial.println(target);

  while (abs(s.getCurrentAngle() - target) > 1) {
    refreshSystem();
    s.startEaseTo(target, globalSpeed);
    delay(50);

    while (s.isMoving()) {
      refreshSystem();
      delay(10);
    }

    if (!isPaused && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
  delay(150);
}

void slowStartCalibration(ServoEasing &servo, int pin, int startAngle, int endAngle) {
  Serial.print("Preparando Pin "); Serial.println(pin);
  delay(800);

  servo.attach(pin);

  for (int p = startAngle; p <= endAngle; p++) {
    refreshSystem();
    servo.write(p);
    delay(80);
  }

  servo.setEasingType(EASE_CUBIC_IN_OUT);
  delay(400);
}

// ===================== SECUENCIA DE TRABAJO =====================

void runWorkSequence() {
  Serial.println(">>> INICIANDO SECUENCIA <<<");

  moveServo(SERVO1, 56, "S1");
  moveServo(SERVO4, 145, "S4");
  moveServo(SERVO3, 60, "S3");
  moveServo(SERVO2, 125, "S2");
  moveServo(SERVO5, 43, "S5");
  safeWait(globalWait);

  moveServo(SERVO2, 100, "S2");
  moveServo(SERVO4, 90, "S4");
  safeWait(globalWait);

  moveServo(SERVO1, 135, "S1");
  moveServo(SERVO4, 90, "S4");
  moveServo(SERVO3, 65, "S3");
  moveServo(SERVO2, 115, "S2");
  moveServo(SERVO5, 130, "S5");
  safeWait(globalWait);

  Serial.println(">>> SECUENCIA FINALIZADA <<<");
}

// ===================== SETUP =====================

void setup() {
  Serial.begin(115200);
  resetCounter++;

  pinMode(PIN_START, INPUT_PULLUP);
  pinMode(PIN_PAUSE, INPUT_PULLUP);
  pinMode(PIN_LED, OUTPUT);

  delay(500);
  Serial.println("\n-----------------------------------");
  Serial.print("SISTEMA ARRANCANDO. Intento #"); Serial.println(resetCounter);

  // 🚩 REVISIÓN DE ESTADO INICIAL
  if (digitalRead(PIN_PAUSE) == LOW) {
    Serial.println(">>> AVISO: El interruptor de PAUSA está CERRADO.");
    Serial.println("Abre el interruptor para poder operar.");
    digitalWrite(PIN_LED, HIGH); // LED fijo si arranca pausado
  } else {
    Serial.println(">>> Sistema listo. LED parpadeando.");
  }

  if (resetCounter > 1) {
    Serial.println("¡ADVERTENCIA! El ESP32 se reinició solo.");
  }
  Serial.println("Esperando botón de Inicio...");
  Serial.println("-----------------------------------");

  // Capturamos el estado real del botón al arrancar para evitar "falsos inicios"
  lastStartState = digitalRead(PIN_START);
}

// ===================== LOOP PRINCIPAL =====================

void loop() {
  refreshSystem();

  int currentStartState = digitalRead(PIN_START);

  // Detección de pulsación (De HIGH a LOW = Botón presionado a Tierra)
  if (currentStartState == LOW && lastStartState == HIGH) {
    delay(150); // Debounce

    if (digitalRead(PIN_START) == LOW) {

      // Seguridad: No arrancar si la pausa está puesta
      if (digitalRead(PIN_PAUSE) == LOW) {
        Serial.println(">>> ERROR: Pausa activa. Abre el interruptor primero.");
        while(digitalRead(PIN_START) == LOW) { refreshSystem(); delay(10); }
        return;
      }

      Serial.println(">>> INICIO DETECTADO <<<");

      if (firstPress) {
        Serial.println("CALIBRACIÓN INICIAL...");
        slowStartCalibration(SERVO1, PIN_S1, 23, 90);
        slowStartCalibration(SERVO2, PIN_S2, 33, 90);
        slowStartCalibration(SERVO3, PIN_S3, 32, 90);
        slowStartCalibration(SERVO4, PIN_S4, 25, 90);
        slowStartCalibration(SERVO5, PIN_S5, 22, 90);
        firstPress = false;
        safeWait(2000);
      }

      runWorkSequence();

      while(digitalRead(PIN_START) == LOW) {
        refreshSystem();
        delay(10);
      }
      Serial.println("En espera...");
    }
  }

  lastStartState = currentStartState;
  delay(10);
}
