#include <ServoEasing.hpp>

// ===================== CONFIGURACIÓN DE PINES =====================
// Botones (Conectar de Pin a GND físico)
const int START_BUTTON_PIN = 19;
const int PAUSE_SWITCH_PIN = 21;

// LED Azul (Interno en la mayoría de ESP32)
const int BLUE_LED_PIN = 2;

// Pines de los Servos (Basados en el hardware verificado)
const int SERVO1_PIN = 23;
const int SERVO2_PIN = 33;
const int SERVO3_PIN = 32;
const int SERVO4_PIN = 25;
const int SERVO5_PIN = 22;

// ===================== VARIABLES GLOBALES =====================
ServoEasing SERVO1, SERVO2, SERVO3, SERVO4, SERVO5;

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;

int espera    = 1000;
int velocidad = 30;

// Variables para LED Azul no bloqueante
unsigned long lastBlinkTime = 0;
bool ledState = LOW;

// ===================== FUNCIONES DE ESTADO (NO BLOQUEANTES) =====================

/**
 * Mantiene el LED parpadeando y verifica el estado del sistema.
 * Debe llamarse frecuentemente en todos los bucles (while/delay).
 */
void refrescarSistema() {
  // 1. Parpadeo del LED Azul (500ms encendido, 500ms apagado)
  if (millis() - lastBlinkTime >= 500) {
    lastBlinkTime = millis();
    ledState = !ledState;
    digitalWrite(BLUE_LED_PIN, ledState);
  }
}

/**
 * Detiene los servos y bloquea la ejecución si el interruptor de pausa está activo.
 */
void verificarPausa() {
  refrescarSistema(); // Asegurar que el LED parpadea mientras revisamos la pausa

  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) { // LOW = Pausa activa (Conexión a GND)
    if (!isPaused) {
      Serial.println("⏸ PAUSA ACTIVADA");
      SERVO1.stop();
      SERVO2.stop();
      SERVO3.stop();
      SERVO4.stop();
      SERVO5.stop();
      isPaused = true;
    }

    // Bloqueo mientras el interruptor esté cerrado (LOW)
    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      refrescarSistema(); // El LED sigue parpadeando durante la pausa
      delay(20);
    }

    if (isPaused) {
      Serial.println("▶ REANUDANDO");
      isPaused = false;
    }
  }
}

// ===================== FUNCIONES DE MOVIMIENTO =====================

/**
 * Mueve un servo a su destino de forma segura y permite pausar.
 */
void moverUnServo(ServoEasing &s, int target, const char* nombre) {
  Serial.print("Moviendo "); Serial.print(nombre); Serial.print(" a "); Serial.println(target);

  while (abs(s.getCurrentAngle() - target) > 1) {
    verificarPausa();

    s.startEaseTo(target, velocidad);
    delay(50); // Estabilización para la librería

    while (s.isMoving()) {
      verificarPausa(); // El LED parpadea y la pausa se detecta durante el movimiento
      delay(10);
    }

    if (!isPaused && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
}

/**
 * Versión de delay que no bloquea ni el LED ni el botón de pausa.
 */
void esperar(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarPausa();
    delay(10);
  }
}

/**
 * Homing inicial lento por seguridad física.
 */
void homingSeguro(ServoEasing &servo, int pin, int destino) {
  servo.attach(pin);
  for (int p = 45; p <= destino; p++) {
    verificarPausa(); // El LED parpadea durante el homing
    servo.write(p);
    delay(40);
  }
  servo.setEasingType(EASE_CUBIC_IN_OUT);
}

// ===================== SECUENCIA DE TRABAJO =====================

void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia...");

  moverUnServo(SERVO1, 56, "S1");
  moverUnServo(SERVO4, 145, "S4");
  moverUnServo(SERVO3, 60, "S3");
  moverUnServo(SERVO2, 125, "S2");
  moverUnServo(SERVO5, 43, "S5");
  esperar(espera);

  moverUnServo(SERVO2, 100, "S2");
  moverUnServo(SERVO4, 90, "S4");
  esperar(espera);

  moverUnServo(SERVO1, 135, "S1");
  moverUnServo(SERVO4, 90, "S4");
  moverUnServo(SERVO3, 65, "S3");
  moverUnServo(SERVO2, 115, "S2");
  moverUnServo(SERVO5, 130, "S5");
  esperar(espera);

  Serial.println(">>> Secuencia completada <<<");
}

// ===================== SETUP =====================

void setup() {
  Serial.begin(115200);

  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);
  pinMode(BLUE_LED_PIN, OUTPUT);

  delay(200);
  Serial.println("\n--- SISTEMA REINICIADO ---");
  Serial.println("El LED azul debe parpadear ahora.");

  lastStartState = digitalRead(START_BUTTON_PIN);
}

// ===================== LOOP PRINCIPAL =====================

void loop() {
  // El LED parpadea y la pausa se revisa constantemente
  verificarPausa();

  int currentState = digitalRead(START_BUTTON_PIN);

  // Detección de pulsación de INICIO (Flanco de bajada: HIGH -> LOW)
  if (currentState == LOW && lastStartState == HIGH) {
    delay(50); // Debounce

    if (digitalRead(START_BUTTON_PIN) == LOW) {
      Serial.println("Botón de inicio detectado.");

      if (firstPress) {
        Serial.println("Realizando Homing inicial de seguridad...");
        homingSeguro(SERVO1, SERVO1_PIN, 90);
        homingSeguro(SERVO2, SERVO2_PIN, 90);
        homingSeguro(SERVO3, SERVO3_PIN, 90);
        homingSeguro(SERVO4, SERVO4_PIN, 90);
        homingSeguro(SERVO5, SERVO5_PIN, 90);
        firstPress = false;
        esperar(espera);
      }

      ejecutarSecuencia();

      // Esperar a que se suelte el botón
      while(digitalRead(START_BUTTON_PIN) == LOW) {
        refrescarSistema();
        delay(10);
      }
    }
  }

  lastStartState = currentState;
  delay(10);
}
