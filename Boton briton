#include <ESP32Servo.h>
#include <ServoEasing.hpp>

/**
 * 🤖 CÓDIGO FINAL BRAZO ROBÓTICO - VERSIÓN POLISHED (PIN 2, 4, 13)
 *
 * Este código resuelve:
 * 1. Botón de inicio (Pin 2): Lógica Active Low (Ground al presionar).
 * 2. Interruptor de Pausa (Pin 4): Lógica Latching (Sostenido).
 *    - Si el interruptor está cerrado (GND), el sistema se detiene y el LED 13 queda ENCENDIDO fijo.
 *    - Si el interruptor está abierto, el sistema corre y el LED 13 parpadea.
 * 3. Reinicios/Brownouts: Encendido ultra-lento uno por uno para no saturar la fuente.
 */

// ===================== CONFIGURACIÓN DE PINES (OG) =====================
const int PIN_START  = 2;   // Botón Start (Presionar = LOW / Tierra)
const int PIN_PAUSE  = 4;   // Interruptor Pausa (Cerrado = LOW / Tierra)
const int PIN_LED    = 13;  // LED de Estado (Parpadea = Trabajando, Fijo = Pausa)

// Pines de los Servos (Confirmados)
const int PIN_S1 = 23;
const int PIN_S2 = 33;
const int PIN_S3 = 32;
const int PIN_S4 = 25;
const int PIN_S5 = 22;

// ===================== VARIABLES GLOBALES =====================
ServoEasing SERVO1, SERVO2, SERVO3, SERVO4, SERVO5;

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;

int globalSpeed = 30; // Velocidad para la secuencia normal
int globalWait  = 1000; // Un segundo de espera entre bloques

// Variables para parpadeo de LED (no bloqueante)
unsigned long lastBlinkTime = 0;
bool ledState = LOW;

// [DIAGNÓSTICO] Para detectar si el ESP32 se reinicia por falta de energía
RTC_DATA_ATTR int resetCounter = 0;

// ===================== FUNCIONES DE ESTADO =====================

/**
 * Mantiene el LED actualizado y revisa la pausa continuamente.
 * - Si está en pausa: LED Fijo
 * - Si está corriendo: LED Parpadeante
 */
void refreshSystem() {
  // 1. Detección de Pausa (LOW = Interruptor cerrado a Tierra)
  if (digitalRead(PIN_PAUSE) == LOW) {
    if (!isPaused) {
      Serial.println("⏸ PAUSA ACTIVADA (Interruptor cerrado)");
      SERVO1.stop(); SERVO2.stop(); SERVO3.stop(); SERVO4.stop(); SERVO5.stop();
      digitalWrite(PIN_LED, HIGH); // LED Fijo durante pausa
      isPaused = true;
    }

    // Mientras el interruptor de pausa esté en LOW (Tierra), el código se bloquea aquí
    while (digitalRead(PIN_PAUSE) == LOW) {
      digitalWrite(PIN_LED, HIGH); // Mantener LED encendido
      delay(20);
    }

    if (isPaused) {
      Serial.println("▶ REANUDANDO (Interruptor abierto)");
      isPaused = false;
    }
  }

  // 2. Parpadeo del LED (500ms) SOLO si no estamos en pausa
  if (!isPaused) {
    if (millis() - lastBlinkTime >= 500) {
      lastBlinkTime = millis();
      ledState = !ledState;
      digitalWrite(PIN_LED, ledState);
    }
  }
}

/**
 * Espera (delay) sin bloquear el LED ni la detección de pausa.
 */
void safeWait(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    refreshSystem();
    delay(10);
  }
}

// ===================== MOVIMIENTOS SEGUROS =====================

/**
 * Mueve un servo individual de forma suave (Easing) y espera a que llegue.
 */
void moveServo(ServoEasing &s, int target, const char* name) {
  if (abs(s.getCurrentAngle() - target) <= 1) return;

  Serial.print("Moviendo "); Serial.print(name); Serial.print(" a "); Serial.println(target);

  while (abs(s.getCurrentAngle() - target) > 1) {
    refreshSystem();
    s.startEaseTo(target, globalSpeed);
    delay(50); // Estabilización

    while (s.isMoving()) {
      refreshSystem();
      delay(10);
    }

    if (!isPaused && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }

  // Pausa tras cada movimiento para evitar picos de corriente
  delay(150);
}

/**
 * Calibración ULTRA-LENTA para el primer arranque.
 * Se mueve grado por grado manualmente.
 */
void slowStartCalibration(ServoEasing &servo, int pin, int startAngle, int endAngle) {
  Serial.print("Preparando Pin "); Serial.println(pin);
  delay(800);

  servo.attach(pin);

  // Movimiento grado a grado muy lento (80ms por grado)
  for (int p = startAngle; p <= endAngle; p++) {
    refreshSystem();
    servo.write(p);
    delay(80);
  }

  // Activamos el suavizado (Easing)
  servo.setEasingType(EASE_CUBIC_IN_OUT);
  delay(400);
}

// ===================== SECUENCIA DE TRABAJO (TUS MOVIMIENTOS) =====================

void runWorkSequence() {
  Serial.println(">>> INICIANDO SECUENCIA <<<");

  // PARTE 1: (Orden solicitado: 1, 4, 3, 2, 5)
  moveServo(SERVO1, 56, "S1");
  moveServo(SERVO4, 145, "S4");
  moveServo(SERVO3, 60, "S3");
  moveServo(SERVO2, 125, "S2");
  moveServo(SERVO5, 43, "S5");
  safeWait(globalWait);

  // PARTE 2: Ajustes específicos (2 a 100, luego 4 a 90)
  moveServo(SERVO2, 100, "S2");
  moveServo(SERVO4, 90, "S4");
  safeWait(globalWait);

  // PARTE 3: Posiciones finales (135, 90, 65, 115, 130)
  moveServo(SERVO1, 135, "S1");
  moveServo(SERVO4, 90, "S4");
  moveServo(SERVO3, 65, "S3");
  moveServo(SERVO2, 115, "S2");
  moveServo(SERVO5, 130, "S5");
  safeWait(globalWait);

  Serial.println(">>> SECUENCIA FINALIZADA <<<");
}

// ===================== SETUP =====================

void setup() {
  Serial.begin(115200);
  resetCounter++;

  pinMode(PIN_START, INPUT_PULLUP);
  pinMode(PIN_PAUSE, INPUT_PULLUP);
  pinMode(PIN_LED, OUTPUT);

  delay(500);
  Serial.println("\n-----------------------------------");
  Serial.print("BRAZO ROBÓTICO - INTENTO #"); Serial.println(resetCounter);

  // Diagnóstico de botones al inicio
  Serial.print("Estado Botón INICIO (P2): "); Serial.println(digitalRead(PIN_START) == LOW ? "PRESIONADO" : "ABIERTO");
  Serial.print("Estado Interruptor PAUSA (P4): "); Serial.println(digitalRead(PIN_PAUSE) == LOW ? "CERRADO (PAUSA)" : "ABIERTO");

  if (resetCounter > 1) {
    Serial.println("¡AVISO! El ESP32 se reinició. Cuidado con la energía.");
  }
  Serial.println("Esperando botón de Inicio para arrancar...");
  Serial.println("-----------------------------------");

  lastStartState = digitalRead(PIN_START);
}

// ===================== LOOP PRINCIPAL =====================

void loop() {
  // El LED parpadea y pausa se revisa constantemente
  refreshSystem();

  int currentStartState = digitalRead(PIN_START);

  // Detección de pulsación (De HIGH a LOW = Botón presionado a Tierra)
  if (currentStartState == LOW && lastStartState == HIGH) {
    delay(150); // Debounce fuerte para evitar inicios accidentales

    if (digitalRead(PIN_START) == LOW) {

      // Si el interruptor de pausa está activo, no permitimos el inicio
      if (digitalRead(PIN_PAUSE) == LOW) {
        Serial.println(">>> ERROR: No se puede iniciar porque la PAUSA está activa.");
        while(digitalRead(PIN_START) == LOW) { refreshSystem(); delay(10); } // Esperar a que suelte
        return;
      }

      Serial.println(">>> BOTÓN INICIO DETECTADO <<<");

      if (firstPress) {
        Serial.println("INICIANDO CALIBRACIÓN SEGURA...");
        slowStartCalibration(SERVO1, PIN_S1, 23, 90);
        slowStartCalibration(SERVO2, PIN_S2, 33, 90);
        slowStartCalibration(SERVO3, PIN_S3, 32, 90);
        slowStartCalibration(SERVO4, PIN_S4, 25, 90);
        slowStartCalibration(SERVO5, PIN_S5, 22, 90);
        firstPress = false;
        safeWait(2000);
      }

      runWorkSequence();

      // Bloquear hasta que el usuario suelte el botón
      while(digitalRead(PIN_START) == LOW) {
        refreshSystem();
        delay(10);
      }
      Serial.println("Listo para nueva orden.");
    }
  }

  lastStartState = currentStartState;
  delay(10);
}
