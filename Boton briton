#include <ESP32Servo.h>
#include <ServoEasing.hpp>

/**
 * 🤖 CÓDIGO FINAL BRAZO ROBÓTICO - VERSIÓN AUTO-CALIBRADA (P2, P4)
 *
 * Este código resuelve:
 * 1. Lógica del Interruptor (Pin 4): Se auto-calibra al arrancar.
 *    - No importa si el interruptor está "abierto" o "cerrado" al encender.
 *    - El brazo arrancará en modo listo, y la PAUSA se activa al CAMBIAR el interruptor de posición.
 * 2. Código Limpio: Se eliminó todo lo relacionado con el LED (Pin 13).
 * 3. Botón Start (Pin 2): Lógica Active Low (Ground al presionar).
 * 4. Estabilidad Eléctrica: Encendido escalonado y movimientos suaves (Easing).
 */

// ===================== CONFIGURACIÓN DE PINES (OG) =====================
const int PIN_START  = 2;   // Botón Start (Presionar = LOW / Tierra)
const int PIN_PAUSE  = 4;   // Interruptor Pausa (Auto-calibrado)

// Pines de los Servos (Confirmados)
const int PIN_S1 = 23;
const int PIN_S2 = 33;
const int PIN_S3 = 32;
const int PIN_S4 = 25;
const int PIN_S5 = 22;

// ===================== VARIABLES GLOBALES =====================
ServoEasing SERVO1, SERVO2, SERVO3, SERVO4, SERVO5;

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;
int normalPauseState; // Se guarda el estado inicial del interruptor al encender

int globalSpeed = 30; // Velocidad para la secuencia normal
int globalWait  = 1000; // Un segundo de espera entre bloques

// [DIAGNÓSTICO] Para detectar si el ESP32 se reinicia por falta de energía
RTC_DATA_ATTR int resetCounter = 0;

// ===================== FUNCIONES DE ESTADO =====================

/**
 * Revisa el interruptor de pausa continuamente.
 * La pausa se activa si el estado actual es DIFERENTE al estado de arranque.
 */
void refreshSystem() {
  int currentPauseState = digitalRead(PIN_PAUSE);

  // Si el estado actual es diferente al que grabamos al encender...
  if (currentPauseState != normalPauseState) {
    if (!isPaused) {
      Serial.println("⏸ PAUSA ACTIVADA (Cambio de posición)");
      if (!firstPress) {
        SERVO1.stop(); SERVO2.stop(); SERVO3.stop(); SERVO4.stop(); SERVO5.stop();
      }
      isPaused = true;
    }

    // Mientras el interruptor siga en la posición de pausa, el código se bloquea aquí
    while (digitalRead(PIN_PAUSE) != normalPauseState) {
      delay(20);
    }

    if (isPaused) {
      Serial.println("▶ CONTINUANDO (Posición original)");
      isPaused = false;
    }
  }
}

/**
 * Espera (delay) sin bloquear la detección de pausa.
 */
void safeWait(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    refreshSystem();
    delay(10);
  }
}

// ===================== MOVIMIENTOS SEGUROS =====================

/**
 * Mueve un servo individual de forma suave (Easing) y espera a que llegue.
 */
void moveServo(ServoEasing &s, int target, const char* name) {
  if (abs(s.getCurrentAngle() - target) <= 1) return;

  Serial.print("Moviendo "); Serial.print(name); Serial.print(" a "); Serial.println(target);

  while (abs(s.getCurrentAngle() - target) > 1) {
    refreshSystem();
    s.startEaseTo(target, globalSpeed);
    delay(50);

    while (s.isMoving()) {
      refreshSystem();
      delay(10);
    }

    if (!isPaused && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
  delay(150);
}

/**
 * Calibración ULTRA-LENTA para el primer arranque.
 */
void slowStartCalibration(ServoEasing &servo, int pin, int startAngle, int endAngle) {
  Serial.print("Preparando Pin "); Serial.println(pin);
  delay(1000); // ⚡ Staggered: Esperar 1s entre servos para estabilidad

  servo.attach(pin);

  // Movimiento grado a grado muy lento (80ms por grado)
  for (int p = startAngle; p <= endAngle; p++) {
    refreshSystem();
    servo.write(p);
    delay(80);
  }

  servo.setEasingType(EASE_CUBIC_IN_OUT);
  delay(400);
}

// ===================== SECUENCIA DE TRABAJO =====================

void runWorkSequence() {
  Serial.println(">>> INICIANDO SECUENCIA <<<");

  moveServo(SERVO1, 56, "S1");
  moveServo(SERVO4, 145, "S4");
  moveServo(SERVO3, 60, "S3");
  moveServo(SERVO2, 125, "S2");
  moveServo(SERVO5, 43, "S5");
  safeWait(globalWait);

  moveServo(SERVO2, 100, "S2");
  moveServo(SERVO4, 90, "S4");
  safeWait(globalWait);

  moveServo(SERVO1, 135, "S1");
  moveServo(SERVO4, 90, "S4");
  moveServo(SERVO3, 65, "S3");
  moveServo(SERVO2, 115, "S2");
  moveServo(SERVO5, 130, "S5");
  safeWait(globalWait);

  Serial.println(">>> SECUENCIA FINALIZADA <<<");
}

// ===================== SETUP =====================

void setup() {
  Serial.begin(115200);
  resetCounter++;

  pinMode(PIN_START, INPUT_PULLUP);
  pinMode(PIN_PAUSE, INPUT_PULLUP);

  delay(500);
  Serial.println("\n-----------------------------------");
  Serial.print("SISTEMA ARRANCANDO. Intento #"); Serial.println(resetCounter);

  // 🚩 AUTO-CALIBRACIÓN DEL INTERRUPTOR
  normalPauseState = digitalRead(PIN_PAUSE);
  Serial.print("Estado de Arranque (Interruptor): "); Serial.println(normalPauseState == LOW ? "LOW" : "HIGH");
  Serial.println("Cualquier cambio en el interruptor activará la PAUSA.");

  if (resetCounter > 1) {
    Serial.println("¡ADVERTENCIA! El ESP32 se reinició solo.");
  }
  Serial.println("Esperando botón de Inicio...");
  Serial.println("-----------------------------------");

  lastStartState = digitalRead(PIN_START);
}

// ===================== LOOP PRINCIPAL =====================

void loop() {
  refreshSystem();

  int currentStartState = digitalRead(PIN_START);

  // Detección de pulsación (De HIGH a LOW = Botón presionado a Tierra)
  if (currentStartState == LOW && lastStartState == HIGH) {
    delay(150); // Debounce

    if (digitalRead(PIN_START) == LOW) {

      // Seguridad: No arrancar si la pausa está puesta (cambió de su estado inicial)
      if (digitalRead(PIN_PAUSE) != normalPauseState) {
        Serial.println(">>> ERROR: Pausa activa. Regresa el interruptor a su posición inicial.");
        while(digitalRead(PIN_START) == LOW) { refreshSystem(); delay(10); }
        return;
      }

      Serial.println(">>> INICIO DETECTADO <<<");

      if (firstPress) {
        Serial.println("CALIBRACIÓN INICIAL...");
        slowStartCalibration(SERVO1, PIN_S1, 23, 90);
        slowStartCalibration(SERVO2, PIN_S2, 33, 90);
        slowStartCalibration(SERVO3, PIN_S3, 32, 90);
        slowStartCalibration(SERVO4, PIN_S4, 25, 90);
        slowStartCalibration(SERVO5, PIN_S5, 22, 90);
        firstPress = false;
        safeWait(2000);
      }

      runWorkSequence();

      // Esperar a soltar botón
      while(digitalRead(PIN_START) == LOW) {
        refreshSystem();
        delay(10);
      }
      Serial.println("Listo para nueva orden.");
    }
  }

  lastStartState = currentStartState;
  delay(10);
}
