#include <ServoEasing.hpp>

// ===================== PINES (Confirmados para este Hardware) =====================
const int START_BUTTON_PIN = 19; // Botón momentáneo para Iniciar (D19 a GND)
const int PAUSE_SWITCH_PIN = 21; // Interruptor sostenido para Pausar (D21 a GND)
const int LED_PIN = 13;

// ===================== VARIABLES =====================
ServoEasing SERVO1, SERVO2, SERVO3, SERVO4, SERVO5;

bool firstPress = true;
int lastStartState = HIGH;
bool isPaused = false;
int espera = 1000;
int velocidad = 30;

// Variables para LED no bloqueante
unsigned long lastBlinkTime = 0;
bool ledState = LOW;

// ===================== FUNCIONES =====================

// Verifica el interruptor de pausa y detiene el movimiento de inmediato
void verificarPausa() {
  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) { // LOW = Switch cerrado (Pausa activa)
    if (!isPaused) {
      Serial.println("⏸ PAUSA ACTIVADA");
      SERVO1.stop();
      SERVO2.stop();
      SERVO3.stop();
      SERVO4.stop();
      SERVO5.stop();
      isPaused = true;
    }

    // Bloqueo total mientras el interruptor esté en LOW
    while (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
      delay(50);
    }

    if (isPaused) {
      Serial.println("▶ REANUDANDO");
      isPaused = false;
    }
  }
}

// Función para mover UN SOLO SERVO con detección de pausa reanudable
void moverUnServo(ServoEasing &s, int target) {
  // Mientras el servo no haya llegado a su destino real
  while (abs(s.getCurrentAngle() - target) > 1) {

    verificarPausa();

    // Iniciar o continuar movimiento hacia el objetivo
    s.startEaseTo(target, velocidad);
    delay(50); // Breve espera para que la librería registre el movimiento

    // Mientras se esté moviendo
    while (s.isMoving()) {
      if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
        verificarPausa();
        break; // Salir del bucle de movimiento para re-evaluar tras la pausa
      }
      delay(10);
    }

    if (!isPaused && !s.isMoving()) {
      if (abs(s.getCurrentAngle() - target) <= 1) break;
    }
  }
}

// Función de espera que no bloquea el botón de pausa
void esperar(int ms) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    verificarPausa();
    delay(10);
  }
}

// Homing inicial lento por seguridad
void homingSeguro(ServoEasing &servo, int pin, int destino) {
  servo.attach(pin);
  Serial.print("Homing pin "); Serial.println(pin);
  for (int p = 45; p <= destino; p++) {
    verificarPausa();
    servo.write(p);
    delay(40);
  }
  servo.setEasingType(EASE_CUBIC_IN_OUT);
}

// ===================== SECUENCIA =====================
void ejecutarSecuencia() {
  Serial.println("Iniciando secuencia de trabajo...");

  moverUnServo(SERVO1, 56);
  moverUnServo(SERVO4, 145);
  moverUnServo(SERVO3, 60);
  moverUnServo(SERVO2, 125);
  moverUnServo(SERVO5, 43);
  esperar(espera);

  moverUnServo(SERVO2, 100);
  moverUnServo(SERVO4, 90);
  esperar(espera);

  moverUnServo(SERVO1, 135);
  moverUnServo(SERVO4, 90);
  moverUnServo(SERVO3, 65);
  moverUnServo(SERVO2, 115);
  moverUnServo(SERVO5, 130);
  esperar(espera);

  Serial.println(">>> Secuencia terminada <<<");
}

// ===================== SETUP =====================
void setup() {
  Serial.begin(115200);

  // Configuración de pines con resistencias Pull-up internas
  pinMode(START_BUTTON_PIN, INPUT_PULLUP);
  pinMode(PAUSE_SWITCH_PIN, INPUT_PULLUP);
  pinMode(LED_PIN, OUTPUT);

  delay(200);
  Serial.println("\n--- SISTEMA REINICIADO (Boton briton) ---");

  if (digitalRead(PAUSE_SWITCH_PIN) == LOW) {
    Serial.println("AVISO: El interruptor de PAUSA está activado al inicio.");
  }

  lastStartState = digitalRead(START_BUTTON_PIN);
  Serial.println("Esperando botón de Inicio...");
}

// ===================== LOOP =====================
void loop() {
  // LED de estado: Parpadeo no bloqueante (Indica que el código corre)
  if (millis() - lastBlinkTime >= 500) {
    lastBlinkTime = millis();
    ledState = !ledState;
    digitalWrite(LED_PIN, ledState);
  }

  // Verificar pausa incluso si no hemos pulsado inicio
  verificarPausa();

  int currentState = digitalRead(START_BUTTON_PIN);

  // Detección de pulsación (Flanco de bajada: de HIGH a LOW)
  if (currentState == LOW && lastStartState == HIGH) {
    delay(50); // Debounce para evitar ruidos

    if (digitalRead(START_BUTTON_PIN) == LOW) {
      Serial.println("¡Botón de inicio detectado!");

      if (firstPress) {
        Serial.println("Realizando Homing de seguridad...");
        // Pines según configuración de hardware en memoria
        homingSeguro(SERVO1, 23, 90);
        homingSeguro(SERVO2, 33, 90);
        homingSeguro(SERVO3, 32, 90);
        homingSeguro(SERVO4, 25, 90);
        homingSeguro(SERVO5, 22, 90);
        firstPress = false;
        esperar(espera);
      }

      ejecutarSecuencia();

      // Bloqueo hasta que se suelte el botón (Evita repeticiones accidentales)
      Serial.println("Suelte el botón para continuar...");
      while(digitalRead(START_BUTTON_PIN) == LOW) {
        delay(10);
      }
    }
  }

  lastStartState = currentState;
  delay(10); // Pequeña pausa para estabilidad
}
